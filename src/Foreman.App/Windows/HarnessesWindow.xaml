<UserControl x:Class="Foreman.App.Windows.HarnessesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI, Arial">

    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF1E2028" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#FF303540" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="DeleteBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FF606878" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTip" Value="Remove custom harness" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="HARNESS MONITORING" FontSize="12" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}" />
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,4,0,0"
                       Text="Uncheck any harness to stop monitoring it. Add custom executables below — Foreman will treat them the same as built-in harnesses." />
        </StackPanel>

        <!-- Column headers -->
        <Grid Grid.Row="2" Margin="4,0,4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="28" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="24" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" Text="Harness" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
            <TextBlock Grid.Column="2" Text="Developer" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
            <TextBlock Grid.Column="3" Text="Status" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" />
        </Grid>

        <!-- Harness list -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="HarnessList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#FF1E2028" BorderThickness="0,0,0,1" Padding="4,8,4,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="24" />
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0" IsChecked="{Binding IsMonitored, Mode=TwoWay}" VerticalAlignment="Center" />

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Text="{Binding Description}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0" />
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{Binding Developer}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11" VerticalAlignment="Center" />

                                <Border Grid.Column="3" CornerRadius="3" Padding="5,2"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Background="{Binding StatusBackground}">
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="{Binding StatusForeground}"
                                               FontSize="10" FontWeight="Bold" />
                                </Border>

                                <!-- Delete button — only visible for custom harnesses -->
                                <Button Grid.Column="4" Content="×"
                                        Style="{StaticResource DeleteBtn}"
                                        Visibility="{Binding DeleteVisibility}"
                                        Tag="{Binding}"
                                        Click="DeleteClick"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Add custom exe row -->
        <Border Grid.Row="6" BorderBrush="#FF303540" BorderThickness="1" CornerRadius="4" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="AddExeBox" Grid.Column="0"
                         Background="{StaticResource SurfaceBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderThickness="0"
                         FontFamily="Consolas, Courier New"
                         FontSize="12"
                         VerticalContentAlignment="Center"
                         KeyDown="AddExeBox_KeyDown"
                         TextChanged="AddExeBox_TextChanged" />
                <TextBlock x:Name="AddExePlaceholder" Grid.Column="0"
                           Text="add exe name, e.g.  myagent.exe"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12" IsHitTestVisible="False"
                           VerticalAlignment="Center" Margin="2,0,0,0" />
                <Button Grid.Column="2" Content="Add" Click="AddClick"
                        Background="{StaticResource SurfaceBrush}" />
            </Grid>
        </Border>

        <!-- Save / Cancel -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Revert" Click="CancelClick" Margin="0,0,8,0" />
            <Button Content="Save" Click="SaveClick"
                    Background="{StaticResource AccentBrush}"
                    Foreground="#FF0D0F12" FontWeight="Bold" Padding="18,6" />
        </StackPanel>
    </Grid>
</UserControl>
