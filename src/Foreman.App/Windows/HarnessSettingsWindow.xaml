<Window x:Class="Foreman.App.Windows.HarnessSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Harness settings" Width="620" Height="800"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe UI, Arial" />
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI, Arial" />
        </Style>
        <Style x:Key="Badge" TargetType="Border">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header + badges -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock x:Name="TitleText" FontSize="19" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI, Arial" />
            <WrapPanel x:Name="BadgePanel" Margin="0,8,0,0" />
        </StackPanel>

        <!-- Trust slider -->
        <Border Grid.Row="1" CornerRadius="8" Padding="14" Margin="0,0,0,12"
                Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Trust" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI, Arial" />
                <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,8"
                           Text="One dial sets how sensitively Foreman interprets this harness, how much it notifies, and how hard it auto-responds. 3 is today's defaults. Applies immediately — no restart." />
                <Slider x:Name="TrustSlider" Minimum="1" Maximum="5" TickFrequency="1"
                        IsSnapToTickEnabled="True" TickPlacement="BottomRight"
                        ValueChanged="TrustSlider_ValueChanged" />
                <Grid Margin="0,2,0,0">
                    <TextBlock Text="1 Locked-down" Style="{StaticResource Muted}" HorizontalAlignment="Left" />
                    <TextBlock Text="5 Hands-off" Style="{StaticResource Muted}" HorizontalAlignment="Right" />
                </Grid>
                <TextBlock x:Name="TrustSummary" Margin="0,8,0,0" TextWrapping="Wrap" FontSize="12"
                           Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI, Arial" />
            </StackPanel>
        </Border>

        <!-- Modalities (the restricted sysprompt) -->
        <Border Grid.Row="2" CornerRadius="8" Padding="14"
                Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Self-service modalities" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI, Arial" />
                <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,8"
                           Text="The small, structured operations this harness is told to honour (delivered over MCP). Tiny-model-friendly by design." />
                <StackPanel x:Name="ModalityPanel" />
            </StackPanel>
        </Border>

        <Border Grid.Row="3" CornerRadius="8" Padding="14" Margin="0,12,0,0"
                Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Harness MCP policy" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI, Arial" />
                <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,8"
                           Text="What this harness is allowed to request over MCP. Browser use is enforced by Foreman's broker/extension path. Desktop computer use is not available to ordinary harness MCP calls yet, so that policy is advisory until a dedicated driver exists." />

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Computer use policy" VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI, Arial" />
                    <ComboBox x:Name="ComputerUseCombo" Grid.Row="0" Grid.Column="1" MinWidth="180" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Browser use policy" VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI, Arial" />
                    <ComboBox x:Name="BrowserUseCombo" Grid.Row="1" Grid.Column="1" MinWidth="180" />
                </Grid>

                <Separator Margin="0,16,0,14" Background="{StaticResource BorderBrush}" />

                <StackPanel x:Name="CuDriverPanel">
                    <TextBlock Text="Foreman shared browser-use driver" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI, Arial" />
                    <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,8"
                               Text="Who may submit Foreman-mediated browser-use (cu_*) actions. This is global Foreman routing, separate from the harness policy above. Actions are still audited, held when risky, panic-haltable, and executed by the browser extension." />
                    <ComboBox x:Name="ForemanDriverCombo" MinWidth="260">
                        <ComboBoxItem Tag="unchanged" Content="Leave Foreman's driver set unchanged" />
                        <ComboBoxItem Tag="include" Content="Add this harness to Foreman's shared driver set" />
                        <ComboBoxItem Tag="remove" Content="Remove this harness from Foreman's shared driver set" />
                        <ComboBoxItem Tag="only" Content="Make this harness Foreman's only driver" />
                        <ComboBoxItem Tag="any" Content="Allow any harness to drive browser use" />
                        <ComboBoxItem Tag="operator" Content="Operator only — no harness driver" />
                    </ComboBox>
                    <TextBlock x:Name="CuDriverNote" Style="{StaticResource Muted}" Margin="0,6,0,0" />
                    <TextBlock x:Name="CuAttentionNote" Style="{StaticResource Muted}" Margin="0,4,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="4" Margin="0,14,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" HorizontalAlignment="Left"
                       FontSize="12" Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI, Arial" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="CancelClick" Margin="0,0,8,0" />
                <Button Content="Save" Click="SaveClick" Padding="18,6"
                        Background="{StaticResource AccentBrush}" Foreground="#FF0D0F12" FontWeight="Bold" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
