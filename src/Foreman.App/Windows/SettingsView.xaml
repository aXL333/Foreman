<UserControl x:Class="Foreman.App.Windows.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI, Arial">

    <UserControl.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,5,0,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
        <!-- Explicit dark-theme template: the default WPF TabItem paints the SELECTED tab with a light system
             background while our foreground stays light, making the active tab unreadable. Mirror the dashboard's
             tab styling (dark surface + accent underline + light text when selected). -->
        <Style TargetType="TabItem">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TB" Background="Transparent" Padding="14,8" Margin="0,0,4,0"
                                CornerRadius="6,6,0,0" BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TB" Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TB" Property="Background" Value="{StaticResource SurfaceBrush}" />
                                <Setter TargetName="TB" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="BodyTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="HelpTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
            <Setter Property="Margin" Value="24,0,0,10" />
        </Style>
        <Style x:Key="FieldRowStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="SectionGapStyle" TargetType="Separator">
            <Setter Property="Margin" Value="0,18,0,14" />
            <Setter Property="Background" Value="{StaticResource BorderBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,18,24,14">
            <StackPanel>
                <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Style="{StaticResource BodyTextStyle}" Margin="0,4,0,0"
                           Text="Tune monitoring, notifications, and safety controls. Presence lock and guardian actions apply immediately; other changes apply when you save." />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="20,16,20,12">
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="4,16,24,24" MaxWidth="680">
                        <TextBlock Text="STARTUP" Style="{StaticResource SectionHeaderStyle}" />
                        <CheckBox x:Name="StartWithWindowsCheck"
                                  Content="Start Foreman when Windows signs in" />
                        <TextBlock Style="{StaticResource HelpTextStyle}"
                                   Text="Creates a per-user HKCU Run entry. No admin rights; Foreman starts in the tray before your first agent session." />

                        <Separator Style="{StaticResource SectionGapStyle}" />

                        <TextBlock Text="MCP SERVER" Style="{StaticResource SectionHeaderStyle}" />
                        <StackPanel Style="{StaticResource FieldRowStyle}">
                            <Label Content="Local MCP port:" Width="180" VerticalAlignment="Center" />
                            <TextBox x:Name="McpPortBox" Width="90" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource BodyTextStyle}" Margin="0,0,0,0"
                                   Text="The local MCP endpoint listens on localhost only. Port changes take effect after a Foreman restart." />

                        <Separator Style="{StaticResource SectionGapStyle}" />

                        <TextBlock Text="GAME MODE" Style="{StaticResource SectionHeaderStyle}" />
                        <CheckBox x:Name="GameModeCheck"
                                  Content="Pause popups while a fullscreen game or presentation is active" />
                        <TextBlock Style="{StaticResource HelpTextStyle}"
                                   Text="Detection, logging, and escalation continue silently. Foreman shows a digest of held notifications after the fullscreen app exits." />
                        <CheckBox x:Name="GameModeBreakThroughCheck"
                                  Content="Let Critical alerts break through game mode"
                                  Margin="24,0,0,0"
                                  IsEnabled="{Binding IsChecked, ElementName=GameModeCheck}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Monitoring">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="4,16,24,24" MaxWidth="700">
                        <TextBlock Text="PROCESS COVERAGE" Style="{StaticResource SectionHeaderStyle}" />
                        <CheckBox x:Name="MonitorAllCheck"
                                  Content="Monitor every process, not just agent child processes" />
                        <TextBlock Style="{StaticResource HelpTextStyle}"
                                   Text="Useful for broad investigations, but noisier. The default watches known harnesses and their descendants." />

                        <Separator Style="{StaticResource SectionGapStyle}" />

                        <TextBlock Text="HANG DETECTION" Style="{StaticResource SectionHeaderStyle}" />
                        <StackPanel Style="{StaticResource FieldRowStyle}">
                            <Label Content="No-I/O hang threshold (min):" Width="220" VerticalAlignment="Center" />
                            <TextBox x:Name="HangBox" Width="80" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FieldRowStyle}">
                            <Label Content="Re-alert same hung process after (min):" Width="220" VerticalAlignment="Center" />
                            <TextBox x:Name="HangRealertBox" Width="80"
                                     ToolTip="After a hang alert for a process, wait this long before alerting on that same PID again. 0 = re-alert each idle stretch." />
                        </StackPanel>
                        <CheckBox x:Name="ScaleIdleCheck"
                                  Content="Lengthen hang timeout when the operator and harness are both idle" />
                        <TextBlock Style="{StaticResource HelpTextStyle}"
                                   Text="Only makes the timeout longer, never shorter. It reduces false hangs while you are away or the harness has no active task; a genuine stall still alerts eventually." />

                        <Separator Style="{StaticResource SectionGapStyle}" />

                        <TextBlock Text="IDLE SELF-CLEANUP" Style="{StaticResource SectionHeaderStyle}" />
                        <CheckBox x:Name="IdleCleanupCheck"
                                  Content="Ask idle harnesses to clean up after themselves" />
                        <TextBlock Style="{StaticResource HelpTextStyle}"
                                   Text="Foreman sends a polite MCP request to checkpoint, stop leftover child processes, and reply or exit. It never kills anything automatically." />
                        <StackPanel Style="{StaticResource FieldRowStyle}" Margin="24,0,0,8">
                            <Label Content="Consider idle after (min):" Width="196" VerticalAlignment="Center" />
                            <TextBox x:Name="IdleCleanupAfterBox" Width="70" />
                        </StackPanel>

                        <Separator Style="{StaticResource SectionGapStyle}" />

                        <TextBlock Text="ADVANCED PROBES" Style="{StaticResource SectionHeaderStyle}" />
                        <CheckBox x:Name="RunElevatedCheck"
                                  Content="Enable elevated helper for per-process network throughput" />
                        <TextBlock Style="{StaticResource HelpTextStyle}"
                                   Text="One UAC prompt. The helper records byte counts per process only - not packet contents, destinations, or deep-packet inspection. The main UI and MCP server stay unprivileged." />
                        <CheckBox x:Name="ScanMcpToolsCheck"
                                  Content="Scan HTTP/SSE MCP tool descriptions for injection wording" />
                        <TextBlock Style="{StaticResource HelpTextStyle}"
                                   Text="Opt-in network probe. Foreman periodically lists tools from configured HTTP/SSE MCP servers and flags descriptions that look like prompt injection or data exfiltration. Stdio servers are never launched." />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Notifications">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="4,16,24,24" MaxWidth="700">
                        <TextBlock Text="POPUPS" Style="{StaticResource SectionHeaderStyle}" />
                        <CheckBox x:Name="NotifyHangCheck" Content="Notify when a process appears hung" />
                        <CheckBox x:Name="NotifyOrphanCheck" Content="Notify on orphaned agent child processes" />
                        <CheckBox x:Name="NotifyCriticalCheck" Content="Notify on critical command alerts" />

                        <Separator Style="{StaticResource SectionGapStyle}" />

                        <TextBlock Text="REPEAT NOISE" Style="{StaticResource SectionHeaderStyle}" />
                        <CheckBox x:Name="CoalesceNotifyCheck"
                                  Content="Group repeat popups for the same incident" />
                        <TextBlock Style="{StaticResource HelpTextStyle}"
                                   Text="Shows the first few notices, then keeps logging repeats without spamming the tray. Critical alerts and escalation transitions still surface individually." />
                        <StackPanel Style="{StaticResource FieldRowStyle}" Margin="24,0,0,8">
                            <Label Content="Repeat grouping window (min):" Width="196" VerticalAlignment="Center" />
                            <TextBox x:Name="SuppressBox" Width="70"
                                     ToolTip="Within this window, repeat popups for the same incident class are coalesced. Every event still appears in the Event Log. 0 = off." />
                        </StackPanel>

                        <Separator Style="{StaticResource SectionGapStyle}" />

                        <TextBlock Text="EVENT RECORDS" Style="{StaticResource SectionHeaderStyle}" />
                        <CheckBox x:Name="OsEventLogCheck"
                                  Content="Mirror lifecycle and security-significant events to Windows Event Log" />
                        <TextBlock Style="{StaticResource HelpTextStyle}"
                                   Text="Writes start, stop, crash, and security-significant records to Windows Logs > Application under source 'Foreman Agent Safety'. Secrets are redacted." />
                        <CheckBox x:Name="PersistLogCheck"
                                  Content="Keep Foreman's local event log across restarts" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Security">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="4,16,24,24" MaxWidth="720">
                        <TextBlock Text="PRESENCE LOCK" Style="{StaticResource SectionHeaderStyle}" />
                        <TextBlock Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8"
                                   Text="Require a Windows Hello or security-key tap before Foreman allows weakening actions: lowering trust, disabling read-auditing, disabling persistent logs, muting protected alerts, or disabling a harness." />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button x:Name="PresenceLockButton" Content="Enable presence lock..." Click="PresenceLockClick" Padding="12,6" />
                            <TextBlock x:Name="PresenceLockStatus" VerticalAlignment="Center" Margin="12,0,0,0"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                        <CheckBox x:Name="PinEveryTapCheck" Click="PinEveryTapClick"
                                  Content="Require PIN or biometric verification on every security-key tap" />
                        <TextBlock Style="{StaticResource HelpTextStyle}"
                                   Text="Off: a roaming security key needs physical touch only. On: also require the key's FIDO2 PIN or biometric. Windows Hello always verifies fully." />

                        <Separator Style="{StaticResource SectionGapStyle}" />

                        <TextBlock Text="HARDENED GUARDIAN" Style="{StaticResource SectionHeaderStyle}" />
                        <TextBlock Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8"
                                   Text="Optional LocalSystem service that holds Foreman's tamper-seal key outside your user session. This makes audit-log seal forgery much harder for same-user agents. One UAC prompt; restart Foreman to activate." />
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="GuardianButton" Content="Enable hardened guardian..." Click="HardenedGuardianClick" Padding="12,6" />
                            <TextBlock x:Name="GuardianStatus" VerticalAlignment="Center" Margin="12,0,0,0"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>

                        <Separator Style="{StaticResource SectionGapStyle}" />

                        <TextBlock Text="DECOY CREDENTIALS" Style="{StaticResource SectionHeaderStyle}" />
                        <CheckBox x:Name="DecoyCredsCheck"
                                  Content="Plant decoy credential honeytokens" />
                        <TextBlock Style="{StaticResource HelpTextStyle}"
                                   Text="Creates believable fake credential files only at paths you do not already use. A real credential file is never shadowed or deleted." />
                        <CheckBox x:Name="DecoyReadAuditCheck"
                                  Content="Audit reads of decoys with the elevated helper"
                                  Margin="24,2,0,2"
                                  IsEnabled="{Binding IsChecked, ElementName=DecoyCredsCheck}" />
                        <TextBlock Style="{StaticResource BodyTextStyle}" Margin="48,0,0,10"
                                   Text="Catches direct file reads that do not invoke a shell command. Audit rules are reverted when disabled." />
                        <CheckBox x:Name="DecoyAwsCanaryCheck"
                                  Content="Embed an AWS canarytoken in the decoy set"
                                  Margin="24,2,0,2"
                                  IsEnabled="{Binding IsChecked, ElementName=DecoyCredsCheck}" />
                        <Grid Margin="48,4,0,0" IsEnabled="{Binding IsChecked, ElementName=DecoyAwsCanaryCheck}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="canarytokens.org AWS access key id:" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,4" />
                            <TextBox Grid.Row="1" x:Name="DecoyAwsKeyIdBox" Width="420" />
                            <TextBlock Grid.Row="2" Text="canarytokens.org AWS secret:" Style="{StaticResource BodyTextStyle}" Margin="0,10,0,4" />
                            <TextBox Grid.Row="3" x:Name="DecoyAwsSecretBox" Width="420" />
                        </Grid>
                        <TextBlock x:Name="DecoyStatusText" Style="{StaticResource BodyTextStyle}" Margin="24,10,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Computer use">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="4,16,24,24" MaxWidth="720">
                        <TextBlock Text="ANDROID / ADB BRIDGE" Style="{StaticResource SectionHeaderStyle}" />
                        <CheckBox x:Name="AdbEnabledCheck"
                                  Content="Enable Foreman's mediated Android device bridge" />
                        <TextBlock Style="{StaticResource HelpTextStyle}"
                                   Text="Off by default. Foreman exposes only bounded devices, screenshot, UI dump, logcat, tap, type, swipe and key actions through the audited cu_* broker—never raw adb shell. A restart is required." />

                        <TextBlock Text="ADB executable" Style="{StaticResource BodyTextStyle}" Margin="0,12,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="AdbPathBox" MinWidth="420" Padding="7,5"
                                     ToolTip="Absolute path to the Android SDK platform-tools adb.exe. PATH lookup is deliberately disabled." />
                            <Button Grid.Column="1" Content="Browse..." Click="BrowseAdbClick" Margin="8,0,0,0" />
                        </Grid>
                        <TextBlock Style="{StaticResource HelpTextStyle}"
                                   Text="Use the absolute platform-tools path. Foreman does not search PATH, which prevents an agent-controlled PATH entry from substituting another executable." />

                        <TextBlock Text="Enrolled device serials" Style="{StaticResource BodyTextStyle}" Margin="0,12,0,4" />
                        <TextBox x:Name="AdbDevicesBox" MinWidth="420" Padding="7,5"
                                 ToolTip="Comma-separated serials from adb devices -l. Empty permits inventory only." />
                        <TextBlock Style="{StaticResource HelpTextStyle}"
                                   Text="Comma-separated. Device-scoped actions fail closed unless the exact serial is enrolled. With one enrolled device, harnesses may omit serial and Foreman stamps it into the audited action." />

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="Test and list devices" Click="ProbeAdbClick" Padding="12,6" />
                            <TextBlock x:Name="AdbStatusText" VerticalAlignment="Center" Margin="12,0,0,0"
                                       TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>

                        <Separator Style="{StaticResource SectionGapStyle}" />

                        <TextBlock Text="AUTHORISATION" Style="{StaticResource SectionHeaderStyle}" />
                        <TextBlock Style="{StaticResource BodyTextStyle}"
                                   Text="Enabling the bridge, changing its executable, or adding a device requires a fresh presence verification. Harnesses then use the same shared driver set configured under Harness settings: every selected harness can submit Android actions through the unified Foreman MCP plugin, subject to its Computer use policy. State-changing actions are always held for operator approval; inventory and captures still pass through the auditor and panic stop." />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Escalation">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="4,16,24,24" MaxWidth="760">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="THRESHOLDS" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock Style="{StaticResource BodyTextStyle}" Margin="0,0,0,12"
                                       Text="These thresholds promote a harness from Watch to Alert, Alarm, then Emergency." />

                            <TextBlock Text="ALERT" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8" />
                            <StackPanel Style="{StaticResource FieldRowStyle}">
                                <Label Content="Medium alerts:" Width="170" VerticalAlignment="Center" />
                                <TextBox x:Name="AlertMediumBox" Width="70" />
                            </StackPanel>

                            <TextBlock Text="ALARM (any one trigger)" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,12,0,8" />
                            <StackPanel Style="{StaticResource FieldRowStyle}">
                                <Label Content="High alerts:" Width="170" VerticalAlignment="Center" />
                                <TextBox x:Name="AlarmHighBox" Width="70" />
                            </StackPanel>
                            <StackPanel Style="{StaticResource FieldRowStyle}">
                                <Label Content="Unique rules:" Width="170" VerticalAlignment="Center" />
                                <TextBox x:Name="AlarmRulesBox" Width="70" />
                            </StackPanel>
                            <StackPanel Style="{StaticResource FieldRowStyle}">
                                <Label Content="Threat categories:" Width="170" VerticalAlignment="Center" />
                                <TextBox x:Name="AlarmCatsBox" Width="70" />
                            </StackPanel>

                            <TextBlock Text="EMERGENCY (any one trigger)" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SeverityCritical}" Margin="0,12,0,8" />
                            <StackPanel Style="{StaticResource FieldRowStyle}">
                                <Label Content="Total alerts:" Width="170" VerticalAlignment="Center" />
                                <TextBox x:Name="EmergencyTotalBox" Width="70" />
                            </StackPanel>
                            <TextBlock Text="Emergency rule IDs:" Style="{StaticResource BodyTextStyle}" Margin="0,4,0,4" />
                            <TextBox x:Name="EmergencyRulesBox"
                                     MinWidth="300" Width="330"
                                     TextWrapping="Wrap" AcceptsReturn="False"
                                     Padding="7,7" />
                            <TextBlock Text="Example: cred-004, cred-005, win-009"
                                       FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="AUTOMATIC RESPONSES" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock Style="{StaticResource BodyTextStyle}" Margin="0,0,0,12"
                                       Text="Foreman can take these non-destructive actions when a harness reaches a tier. Auto-kill and auto-mute stay manual." />

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="82" />
                                    <ColumnDefinition Width="86" />
                                    <ColumnDefinition Width="92" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Ask" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Audit" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="Cleanup" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Alert" VerticalAlignment="Center" FontSize="12" />
                                <CheckBox Grid.Row="1" Grid.Column="1" x:Name="AlertAskCheck" />
                                <CheckBox Grid.Row="1" Grid.Column="2" x:Name="AlertAuditCheck" IsEnabled="False"
                                          ToolTip="Adversarial audit only fires at Alarm and above." />
                                <CheckBox Grid.Row="1" Grid.Column="3" x:Name="AlertCleanupCheck" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Alarm" VerticalAlignment="Center" FontSize="12" />
                                <CheckBox Grid.Row="2" Grid.Column="1" x:Name="AlarmAskCheck" />
                                <CheckBox Grid.Row="2" Grid.Column="2" x:Name="AlarmAuditCheck" />
                                <CheckBox Grid.Row="2" Grid.Column="3" x:Name="AlarmCleanupCheck" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Emergency" VerticalAlignment="Center" FontSize="12" />
                                <CheckBox Grid.Row="3" Grid.Column="1" x:Name="EmergencyAskCheck" />
                                <CheckBox Grid.Row="3" Grid.Column="2" x:Name="EmergencyAuditCheck" />
                                <CheckBox Grid.Row="3" Grid.Column="3" x:Name="EmergencyCleanupCheck" />
                            </Grid>
                            <StackPanel Style="{StaticResource FieldRowStyle}">
                                <Label Content="Re-fire cooldown (min):" Width="170" VerticalAlignment="Center" />
                                <TextBox x:Name="AutoResponseCooldownBox" Width="70"
                                         ToolTip="Per harness and action, do not repeat the same automatic response within this window." />
                            </StackPanel>
                            <Separator Margin="0,14,0,12" />
                            <CheckBox x:Name="ScheduledAuditCheck"
                                      Content="Schedule independent cross-harness audits"
                                      FontWeight="SemiBold" Margin="0,0,0,8"
                                      ToolTip="A different active harness reviews recent redacted events. Requires LLM triage and an eligible auditor." />
                            <TextBlock Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8"
                                       TextWrapping="Wrap"
                                       Text="Audits are queued in the auditor mailbox and delivered live when possible. The audited harness can never audit itself." />
                            <StackPanel Style="{StaticResource FieldRowStyle}">
                                <Label Content="Every N alerts (0 = off):" Width="190" VerticalAlignment="Center" />
                                <TextBox x:Name="ScheduledAuditEveryBox" Width="70" />
                            </StackPanel>
                            <StackPanel Style="{StaticResource FieldRowStyle}">
                                <Label Content="Interval min (0 = off):" Width="190" VerticalAlignment="Center" />
                                <TextBox x:Name="ScheduledAuditIntervalBox" Width="70" />
                            </StackPanel>
                            <StackPanel Style="{StaticResource FieldRowStyle}">
                                <Label Content="Per-harness cooldown:" Width="190" VerticalAlignment="Center" />
                                <TextBox x:Name="ScheduledAuditCooldownBox" Width="70" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Style="{StaticResource BodyTextStyle}"
                               Text="Some changes, such as port and guardian activation, require a Foreman restart." />
                    <TextBlock x:Name="SavedStatus" Foreground="{StaticResource AccentBrush}" FontSize="12" Margin="0,2,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Revert" Click="RevertClick" Margin="0,0,8,0" MinWidth="92" />
                    <Button Content="Save" Click="SaveClick" MinWidth="92"
                            Background="{StaticResource AccentBrush}"
                            Foreground="#FF0D0F12" FontWeight="Bold" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
