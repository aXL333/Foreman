<Window x:Class="Foreman.App.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Foreman Agent Safety — Settings"
        Icon="/Resources/foreman.ico"
        Width="500" Height="820"
        MinHeight="680"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI, Arial">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#FF303540" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,4,0,4" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF1E2028" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#FF303540" />
            <Setter Property="Padding" Value="18,6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />   <!-- 0: header -->
                <RowDefinition Height="16"   />
                <RowDefinition Height="Auto" />   <!-- 2: general -->
                <RowDefinition Height="16"   />
                <RowDefinition Height="Auto" />   <!-- 4: MCP -->
                <RowDefinition Height="16"   />
                <RowDefinition Height="Auto" />   <!-- 6: process thresholds -->
                <RowDefinition Height="16"   />
                <RowDefinition Height="Auto" />   <!-- 8: notifications -->
                <RowDefinition Height="16"   />
                <RowDefinition Height="Auto" />   <!-- 10: escalation thresholds -->
                <RowDefinition Height="*"    />
                <RowDefinition Height="Auto" />   <!-- 12: buttons -->
            </Grid.RowDefinitions>

            <!-- ── Header ───────────────────────────────────────────────────── -->
            <TextBlock Grid.Row="0" Text="SETTINGS" FontSize="12" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}" />

            <!-- ── General ───────────────────────────────────────────────────── -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="GENERAL" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8" />
                <CheckBox x:Name="StartWithWindowsCheck"
                          Content="Start Foreman Agent Safety when you sign in to Windows" />
                <TextBlock TextWrapping="Wrap" FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}" Margin="22,2,0,0"
                           Text="Adds a per-user startup entry (HKCU Run — no admin rights). Foreman Agent Safety starts quietly in the system tray, so monitoring and the MCP server are up before your first agent session." />

                <CheckBox x:Name="GameModeCheck" Content="Game mode — pause popups while a fullscreen game/app is running"
                          Margin="0,12,0,0" />
                <TextBlock TextWrapping="Wrap" FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}" Margin="22,2,0,0"
                           Text="Auto-detects fullscreen games, apps, and presentation mode (via the same Windows signal that mutes toast notifications) and holds Foreman Agent Safety's on-screen popups and alarm windows so they don't barge in. It keeps detecting, logging, and escalating silently, and shows a digest of what it held when you exit the game." />
                <CheckBox x:Name="GameModeBreakThroughCheck" Content="…but still let Critical alerts interrupt"
                          Margin="40,4,0,0" IsEnabled="{Binding IsChecked, ElementName=GameModeCheck}" />
            </StackPanel>

            <!-- ── MCP Server ────────────────────────────────────────────────── -->
            <StackPanel Grid.Row="4">
                <TextBlock Text="MCP SERVER" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal">
                    <Label Content="Port:" VerticalAlignment="Center" Width="210" />
                    <TextBox x:Name="McpPortBox" Width="80" />
                </StackPanel>
            </StackPanel>

            <!-- ── Process Thresholds ────────────────────────────────────────── -->
            <StackPanel Grid.Row="6">
                <TextBlock Text="PROCESS THRESHOLDS" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Label Content="Hang threshold (min):" VerticalAlignment="Center" Width="210" />
                    <TextBox x:Name="HangBox" Width="80" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Label Content="Hook jam threshold (min):" VerticalAlignment="Center" Width="210" />
                    <TextBox x:Name="HookBox" Width="80" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Label Content="Coalesce repeat popups within (min):" VerticalAlignment="Center" Width="210" />
                    <TextBox x:Name="SuppressBox" Width="80"
                             ToolTip="After a hang/orphan popup for a harness, fold further popups of the same kind within this window into one rollup with a count (e.g. 'Codex process hang ×4'), instead of separate toasts. Every event still appears in the Event Log. 0 = off." />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Content="Hang re-alert cooldown (min):" VerticalAlignment="Center" Width="210" />
                    <TextBox x:Name="HangRealertBox" Width="80"
                             ToolTip="After a hang alert for a process, wait this long before alerting on it again (stops bursty children re-firing). 0 = re-alert each idle stretch." />
                </StackPanel>
                <CheckBox x:Name="ScaleIdleCheck" Content="Scale the hang threshold by activity (operator presence + harness task)"
                          Margin="0,10,0,0" />
                <TextBlock TextWrapping="Wrap" FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}" Margin="22,2,0,0"
                           Text="A process quiet for the threshold means little if nobody's at the keyboard and the harness has no task running. When on, the hang timeout lengthens (up to a capped ceiling) while you're away and/or the harness is parked — it only ever waits LONGER, never shorter, so it can't add alerts or hide anything. Reads only idle duration (no keylogging). A genuine stall always alerts eventually." />
            </StackPanel>

            <!-- ── Notifications ─────────────────────────────────────────────── -->
            <StackPanel Grid.Row="8">
                <TextBlock Text="NOTIFICATIONS" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8" />
                <CheckBox x:Name="NotifyHangCheck" Content="Notify on hang detected" />
                <CheckBox x:Name="NotifyOrphanCheck" Content="Notify on orphaned process" />
                <CheckBox x:Name="NotifyCriticalCheck" Content="Notify on critical command" />
                <CheckBox x:Name="CoalesceNotifyCheck"
                          Content="Coalesce repetitive hang/orphan popups (rollup)"
                          Margin="0,12,0,0" />
                <TextBlock TextWrapping="Wrap" FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}" Margin="22,2,0,0"
                           Text="When a harness floods you with hang/orphan notices, show only the first few per harness then fold the rest into one rollup notice per window. Security and critical alerts are never coalesced, and every event still appears in the log." />
                <CheckBox x:Name="OsEventLogCheck"
                          Content="Mirror lifecycle + significant events to the Windows Event Log"
                          Margin="0,12,0,0" />
                <TextBlock TextWrapping="Wrap" FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}" Margin="22,2,0,0"
                           Text="Blackbox handoff (Defender-style): writes start/stop/crash and security-significant events to Event Viewer (Windows Logs → Application, source 'Foreman Agent Safety') so the record survives Foreman being killed. Needs Run Elevated once to register the source; until then it degrades to the on-disk log. Secrets are redacted." />
                <CheckBox x:Name="PersistLogCheck" Content="Keep the event log across restarts" />
                <CheckBox x:Name="MonitorAllCheck" Content="Monitor all processes (not just harness children)"
                          Margin="0,12,0,4" />
                <CheckBox x:Name="RunElevatedCheck"
                          Content="Run elevated for per-process Network (opt-in)"
                          Margin="0,12,0,0" />
                <TextBlock TextWrapping="Wrap" FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}" Margin="22,2,0,0"
                           Text="Launches a small, elevated ETW helper (one UAC prompt) that meters per-process network throughput — byte counts per process only, NOT packet contents or destinations (no deep packet inspection). Only the helper runs elevated; Foreman Agent Safety's UI, MCP server, and kill action stay unprivileged. Leave off if you don't need the Net column." />
                <CheckBox x:Name="ScanMcpToolsCheck"
                          Content="Scan MCP tool descriptions for injection (opt-in)"
                          Margin="0,12,0,0" />
                <TextBlock TextWrapping="Wrap" FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}" Margin="22,2,0,0"
                           Text="Periodically connects to the HTTP/SSE MCP servers your harnesses use, lists their tools, and flags tool names or descriptions that read like prompt injection or data exfil (e.g. 'ignore previous instructions', 'email the .env'). This is the only feature that makes outbound connections to third-party servers; stdio servers are never launched. Leave off unless you want this network probe." />
                <CheckBox x:Name="IdleCleanupCheck"
                          Content="Ask idle harnesses to clean up after themselves (opt-in)"
                          Margin="0,12,0,0" />
                <TextBlock TextWrapping="Wrap" FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}" Margin="22,2,0,0"
                           Text="When an agent's whole process tree has been I/O-silent past the threshold, Foreman Agent Safety asks it over MCP to pack up cleanly: checkpoint work, stop leftover child processes, and reply or exit. A polite request only — nothing is killed, and an unanswered request just raises a notice. The manual trigger (Process Monitor → right-click → Request self-cleanup) always works." />
                <StackPanel Orientation="Horizontal" Margin="22,6,0,0">
                    <Label Content="Consider idle after (min):" VerticalAlignment="Center" Width="188" />
                    <TextBox x:Name="IdleCleanupAfterBox" Width="60" />
                </StackPanel>

                <CheckBox x:Name="DecoyCredsCheck"
                          Content="Plant decoy credential honeytokens (opt-in)"
                          Margin="0,12,0,0" />
                <TextBlock TextWrapping="Wrap" FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}" Margin="22,2,0,0"
                           Text="Plants believable FAKE credential files only at paths you don't already use (~/.aws/credentials, ~/.npmrc, ~/.ssh/id_rsa, .git-credentials, …) so a Miasma-style harvester's own enumeration trips a near-zero-false-positive alert. A working credential file is never shadowed, and removing a decoy never deletes a real file. If you later need one of those paths for real credentials, just write them there — Foreman detects the decoy is gone and retires that slot automatically, never touching your real file. (Turning this off removes Foreman's decoys.)" />
                <CheckBox x:Name="DecoyReadAuditCheck"
                          Content="…and audit READS of decoys (elevated — catches the silent fopen)"
                          Margin="40,6,0,0" />
                <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="62,2,0,0"
                           Text="Runs the elevated sidecar (one UAC prompt) to place a Windows audit rule on each decoy and tail the Security log, so even a direct file read (no shell command) by a harvester fires a Critical alert. The audit rule + policy change are reverted when you turn this off. Applies on next launch / when toggled." />
                <CheckBox x:Name="DecoyAwsCanaryCheck"
                          Content="Embed an AWS canarytoken (beacons when a stolen decoy key is used)"
                          Margin="40,6,0,0" />
                <StackPanel Orientation="Vertical" Margin="40,4,0,0">
                    <Label Content="canarytokens.org AWS access key id:" />
                    <TextBox x:Name="DecoyAwsKeyIdBox" Width="320" />
                    <Label Content="canarytokens.org AWS secret:" Margin="0,4,0,0" />
                    <TextBox x:Name="DecoyAwsSecretBox" Width="320" />
                </StackPanel>
                <TextBlock x:Name="DecoyStatusText" TextWrapping="Wrap" FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}" Margin="22,6,0,0" />

                <Separator Margin="0,16,0,8" />
                <TextBlock Text="PRESENCE LOCK" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"
                           Text="Require a Windows Hello or security-key (YubiKey/FIDO2) tap to WEAKEN Foreman — lower a harness's Trust, disable read-auditing, disable the persistent log, mute a protected alert, or disable a harness. The tap is the one thing a rogue agent running as you can't satisfy. Disabling the lock needs a tap too." />
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="PresenceLockButton" Content="Enable presence lock…" Click="PresenceLockClick" Padding="12,5" />
                    <TextBlock x:Name="PresenceLockStatus" VerticalAlignment="Center" Margin="12,0,0,0"
                               Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>
                <CheckBox x:Name="PinEveryTapCheck" Margin="0,10,0,0" Click="PinEveryTapClick"
                          Content="Require PIN / biometric on every tap (security keys)" />
                <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="22,2,0,0"
                           Text="Off (default): a roaming security key (YubiKey) needs just a single touch — no PIN every time. On: also require the key's FIDO2 PIN or a biometric (stronger, but prompts every tap). A physical touch is always required either way; Windows Hello always verifies fully regardless of this setting." />

                <Separator Margin="0,16,0,8" />
                <TextBlock Text="HARDENED GUARDIAN (ADVANCED)" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"
                           Text="Installs a small LocalSystem service that holds Foreman's tamper-seal key behind the SYSTEM boundary, so a monitored agent running as you can no longer forge the audit log's seal — moving that protection from tamper-EVIDENT to tamper-PROOF. One UAC prompt to install; restart Foreman to activate. The default per-user app is otherwise unchanged. Off by default — most users don't need it." />
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="GuardianButton" Content="Enable hardened guardian…" Click="HardenedGuardianClick" Padding="12,5" />
                    <TextBlock x:Name="GuardianStatus" VerticalAlignment="Center" Margin="12,0,0,0"
                               Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- ── Escalation Thresholds ─────────────────────────────────────── -->
            <StackPanel Grid.Row="10">
                <TextBlock Text="ESCALATION THRESHOLDS" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                <TextBlock TextWrapping="Wrap" FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,0,0,10">
                    These thresholds control when Foreman Agent Safety promotes a harness from Watch → Alert → Alarm → Emergency.
                </TextBlock>

                <!-- Alert thresholds -->
                <TextBlock Text="→ ALERT level" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,6" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Label Content="Medium-severity alerts ≥:" VerticalAlignment="Center" Width="210" />
                    <TextBox x:Name="AlertMediumBox" Width="60" />
                </StackPanel>

                <!-- Alarm thresholds -->
                <TextBlock Text="→ ALARM level  (any one trigger)" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}" Margin="0,6,0,6" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Label Content="High-severity alerts ≥:" VerticalAlignment="Center" Width="210" />
                    <TextBox x:Name="AlarmHighBox" Width="60" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Label Content="Unique rules fired ≥:" VerticalAlignment="Center" Width="210" />
                    <TextBox x:Name="AlarmRulesBox" Width="60" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Label Content="Distinct threat categories ≥:" VerticalAlignment="Center" Width="210" />
                    <TextBox x:Name="AlarmCatsBox" Width="60" />
                </StackPanel>

                <!-- Emergency thresholds -->
                <TextBlock Text="→ EMERGENCY level  (any one trigger)" FontSize="10" FontWeight="SemiBold"
                           Foreground="#FFFF6666" Margin="0,6,0,6" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Label Content="Total alerts ≥:" VerticalAlignment="Center" Width="210" />
                    <TextBox x:Name="EmergencyTotalBox" Width="60" />
                </StackPanel>
                <StackPanel Orientation="Vertical" Margin="0,0,0,0">
                    <Label Content="Emergency rule IDs (comma-separated):" />
                    <TextBox x:Name="EmergencyRulesBox"
                             Width="420" HorizontalAlignment="Left"
                             TextWrapping="Wrap" AcceptsReturn="False"
                             Padding="6,6" />
                    <TextBlock Text="e.g. cred-004, cred-005, win-009, cred-018, cred-019"
                               FontSize="9" Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,3,0,0" />
                </StackPanel>

                <!-- Automatic responses per tier -->
                <TextBlock Text="→ AUTOMATIC RESPONSES" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}" Margin="0,14,0,4" />
                <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"
                           Text="When a harness reaches a tier, Foreman Agent Safety can automatically take these non-destructive actions. There is deliberately no auto-kill or auto-mute here — destructive/silencing actions stay manual and confirmed. Adversarial audit only fires for security-relevant escalations (Alarm and above)." />
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Ask Harness" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Adv. Audit"  FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Self-cleanup" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Alert"     VerticalAlignment="Center" FontSize="11" />
                    <CheckBox  Grid.Row="1" Grid.Column="1" x:Name="AlertAskCheck" />
                    <CheckBox  Grid.Row="1" Grid.Column="2" x:Name="AlertAuditCheck" IsEnabled="False"
                               ToolTip="Adversarial audit only fires at Alarm and above (Alert isn't audit-worthy on its own)." />
                    <CheckBox  Grid.Row="1" Grid.Column="3" x:Name="AlertCleanupCheck" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Alarm"     VerticalAlignment="Center" FontSize="11" />
                    <CheckBox  Grid.Row="2" Grid.Column="1" x:Name="AlarmAskCheck" />
                    <CheckBox  Grid.Row="2" Grid.Column="2" x:Name="AlarmAuditCheck" />
                    <CheckBox  Grid.Row="2" Grid.Column="3" x:Name="AlarmCleanupCheck" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Emergency" VerticalAlignment="Center" FontSize="11" />
                    <CheckBox  Grid.Row="3" Grid.Column="1" x:Name="EmergencyAskCheck" />
                    <CheckBox  Grid.Row="3" Grid.Column="2" x:Name="EmergencyAuditCheck" />
                    <CheckBox  Grid.Row="3" Grid.Column="3" x:Name="EmergencyCleanupCheck" />
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Label Content="Re-fire cooldown (min):" VerticalAlignment="Center" Width="150" />
                    <TextBox x:Name="AutoResponseCooldownBox" Width="60"
                             ToolTip="Per harness + action: don't repeat the same auto-response within this window." />
                </StackPanel>
            </StackPanel>

            <!-- ── Buttons ───────────────────────────────────────────────────── -->
            <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="CancelClick" Margin="0,0,8,0" />
                <Button Content="Save" Click="SaveClick"
                        Background="{StaticResource AccentBrush}"
                        Foreground="#FF0D0F12" FontWeight="Bold" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
