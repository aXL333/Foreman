<Window x:Class="Foreman.App.Windows.EscalationAlarmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Foreman — EMERGENCY ALERT"
        Width="660" Height="500"
        MinWidth="500" MinHeight="400"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI, Arial"
        WindowStartupLocation="CenterScreen"
        Topmost="True">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- alarm banner -->
            <RowDefinition Height="12"   />
            <RowDefinition Height="Auto" />   <!-- harness name + trigger -->
            <RowDefinition Height="12"   />
            <RowDefinition Height="Auto" />   <!-- session summary -->
            <RowDefinition Height="12"   />
            <RowDefinition Height="*"    />   <!-- reason + explanation -->
            <RowDefinition Height="16"   />
            <RowDefinition Height="Auto" />   <!-- action buttons -->
        </Grid.RowDefinitions>

        <!-- ── Alarm banner ─────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#FF3A0808" CornerRadius="4" Padding="14,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" FontSize="20" Foreground="#FFFF4444"
                           VerticalAlignment="Center" Margin="0,0,10,0" />
                <StackPanel>
                    <TextBlock Text="EMERGENCY ESCALATION"
                               FontSize="14" FontWeight="Bold" Foreground="#FFFF6666" />
                    <TextBlock Text="{Binding SubTitle}"
                               FontSize="11" Foreground="#FFCC8888" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Harness name + trigger ────────────────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="HARNESS" FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,3" />
                <TextBlock Text="{Binding HarnessDisplayName}"
                           FontSize="16" FontWeight="SemiBold" />
            </StackPanel>

            <Border Grid.Column="2" Background="#FF1A0808" CornerRadius="4" Padding="10,6">
                <StackPanel>
                    <TextBlock Text="TRIGGER RULE" FontSize="9" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,3" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding TriggerRuleId}"
                                   FontFamily="Consolas, Courier New" FontSize="11"
                                   Foreground="#FFFF8888" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding TriggerRuleName}"
                                   FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Session summary ───────────────────────────────────────────── -->
        <Border Grid.Row="4" Background="#FF14161E" CornerRadius="4" Padding="12,8">
            <WrapPanel Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="Total alerts: " Foreground="{StaticResource TextMutedBrush}" FontSize="11" />
                    <TextBlock Text="{Binding TotalAlerts}" Foreground="#FFFF6666"
                               FontWeight="Bold" FontSize="11" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="Unique rules: " Foreground="{StaticResource TextMutedBrush}" FontSize="11" />
                    <TextBlock Text="{Binding UniqueRules}" Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="Bold" FontSize="11" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="Categories: " Foreground="{StaticResource TextMutedBrush}" FontSize="11" />
                    <TextBlock Text="{Binding CategoriesLabel}" Foreground="#FFFF8888"
                               FontWeight="Bold" FontSize="11" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Session: " Foreground="{StaticResource TextMutedBrush}" FontSize="11" />
                    <TextBlock Text="{Binding SessionDuration}"
                               FontFamily="Consolas, Courier New" Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11" />
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- ── Reason / explanation ──────────────────────────────────────── -->
        <ScrollViewer Grid.Row="6" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="ESCALATION REASON" FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,6" />
                <TextBlock Text="{Binding Reason}" TextWrapping="Wrap"
                           FontSize="12" LineHeight="20"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,16" />

                <TextBlock Text="WHAT THIS MEANS" FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,6" />
                <TextBlock Text="{Binding Explanation}" TextWrapping="Wrap"
                           FontSize="12" LineHeight="20"
                           Foreground="{StaticResource TextPrimaryBrush}" />
            </StackPanel>
        </ScrollViewer>

        <!-- ── Action buttons ────────────────────────────────────────────── -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Destructive actions on the left -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="☠ Kill Harness Processes" Click="KillClick"
                        Background="#FF3A0808" Foreground="#FFFF6666"
                        BorderBrush="#FF5A1818" Padding="14,8" FontWeight="Bold"
                        Margin="0,0,10,0" Cursor="Hand" />
                <Button Content="⊘ Disable &amp; Ignore" Click="DisableClick"
                        Background="#FF1E2028" Foreground="{StaticResource TextMutedBrush}"
                        BorderBrush="#FF303540" Padding="12,8"
                        Cursor="Hand" />
            </StackPanel>

            <!-- Safe actions on the right -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Open Log" Click="OpenLogClick"
                        Background="#FF1E2028" Foreground="{StaticResource TextPrimaryBrush}"
                        BorderBrush="#FF303540" Padding="12,8" Margin="0,0,8,0"
                        Cursor="Hand" />
                <Button Content="Acknowledge" Click="AcknowledgeClick"
                        Background="{StaticResource AccentBrush}"
                        Foreground="#FF0D0F12" FontWeight="Bold" Padding="16,8"
                        Cursor="Hand" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
