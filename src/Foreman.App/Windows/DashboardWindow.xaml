<Window x:Class="Foreman.App.Windows.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Foreman"
        Width="880" Height="520"
        MinWidth="640" MinHeight="340"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI, Arial"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF1E2028" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#FF303540" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- r0: header — title + harness chips + summary -->
            <RowDefinition Height="*" />      <!-- r1: content — alert feed or empty state -->
            <RowDefinition Height="Auto" />   <!-- r2: footer toolbar -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#FF0D0F16"
                BorderBrush="#FF1E2030" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />    <!-- FOREMAN title -->
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />       <!-- harness chips -->
                    <ColumnDefinition Width="Auto" />    <!-- summary text -->
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="FOREMAN"
                           FontSize="13" FontWeight="Bold"
                           FontFamily="Segoe UI, Arial"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center" />

                <!-- One chip per harness that has alerts.  Empty = "all clear" hint. -->
                <ItemsControl Grid.Column="2" x:Name="HarnessPanel"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="3" Padding="7,3" Margin="0,0,8,0"
                                    Background="{Binding LevelBg}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding LevelLabel}"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="{Binding LevelFg}" />
                                    <TextBlock Text="  " />
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="10"
                                               Foreground="{Binding LevelFg}" />
                                    <TextBlock Text="  ·  " FontSize="10"
                                               Foreground="{Binding LevelFg}" Opacity="0.65" />
                                    <TextBlock Text="{Binding CountLabel}"
                                               FontSize="10"
                                               Foreground="{Binding LevelFg}" Opacity="0.85" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Grid.Column="3" x:Name="SummaryLabel"
                           FontSize="11"
                           FontFamily="Segoe UI, Arial"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ── Empty state (shown when no security alerts exist) ─────────────── -->
        <Grid Grid.Row="1" x:Name="EmptyPanel" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5">
                <TextBlock Text="No security alerts this session"
                           FontSize="14" FontFamily="Segoe UI, Arial"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Foreman is watching"
                           FontSize="11" FontFamily="Segoe UI, Arial"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,5,0,0" />
            </StackPanel>
        </Grid>

        <!-- ── Alert feed ─────────────────────────────────────────────────────── -->
        <!-- Click any row to open AlertDetailWindow for that event. -->
        <ListView Grid.Row="1" x:Name="AlertList"
                  Background="{StaticResource SurfaceBrush}"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  SelectionChanged="AlertList_SelectionChanged">

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FF1A1C28" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FF22253A" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#FF1E2030" BorderThickness="0,0,0,1"
                            Padding="14,9,14,9">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />   <!-- headline row -->
                                <RowDefinition Height="Auto" />   <!-- subline row (optional) -->
                            </Grid.RowDefinitions>

                            <!-- Headline: sev badge | tag badge | text | time | arrow -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />    <!-- severity badge -->
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="52" />    <!-- category tag badge -->
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />     <!-- headline text -->
                                    <ColumnDefinition Width="62" />    <!-- time ago -->
                                    <ColumnDefinition Width="12" />    <!-- › arrow -->
                                </Grid.ColumnDefinitions>

                                <!-- Severity badge (red/orange/yellow) -->
                                <Border Grid.Column="0" CornerRadius="3" Padding="4,2"
                                        Background="{Binding SeverityBrush}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SeverityLabel}"
                                               FontSize="9" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </Border>

                                <!-- Category tag badge (NET / CRED / ESC / HANG …) -->
                                <Border Grid.Column="2" CornerRadius="3" Padding="4,2"
                                        Background="{Binding TagBg}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TagBadge}"
                                               FontSize="9" FontWeight="Bold" Foreground="{Binding TagFg}"
                                               HorizontalAlignment="Center" />
                                </Border>

                                <!-- Headline text -->
                                <TextBlock Grid.Column="4" Text="{Binding Headline}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />

                                <!-- Relative time -->
                                <TextBlock Grid.Column="5" Text="{Binding TimeAgo}"
                                           FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />

                                <!-- Click indicator arrow -->
                                <TextBlock Grid.Column="6" Text="›"
                                           FontSize="14"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <!-- SubLine: command preview / escalation categories / hang details
                                 Collapsed when SubLine is empty (non-command events that have no extra detail). -->
                            <TextBlock Grid.Row="1"
                                       Text="{Binding SubLine}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       FontFamily="Consolas, Courier New"
                                       Margin="0,4,0,0"
                                       Visibility="{Binding SubLineVisibility}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- ── Footer toolbar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="#FF0D0F16"
                BorderBrush="#FF1E2030" BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Open Full Log" Click="OpenLogClick" />
                </StackPanel>
                <TextBlock x:Name="FooterText"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontSize="11" FontFamily="Segoe UI, Arial"
                           Foreground="{StaticResource TextMutedBrush}" />
            </Grid>
        </Border>
    </Grid>
</Window>
