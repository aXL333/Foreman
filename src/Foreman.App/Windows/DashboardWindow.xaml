<Window x:Class="Foreman.App.Windows.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Foreman"
        Icon="/Resources/foreman.ico"
        Width="1080" Height="680"
        MinWidth="820" MinHeight="500"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI, Arial"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF222632" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FF4A5160" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF151820" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FF0B0D12" />
            <Setter Property="BorderBrush" Value="#FFE9C267" />
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI, Arial" />
        </Style>

        <Style x:Key="MetricCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- r0: header -->
            <RowDefinition Height="Auto" />   <!-- r1: status strip -->
            <RowDefinition Height="*" />      <!-- r2: content -->
            <RowDefinition Height="Auto" />   <!-- r3: footer toolbar -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#FF0B0D12"
                BorderBrush="#FF1E2030" BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />    <!-- FOREMAN brand -->
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />       <!-- harness chips -->
                    <ColumnDefinition Width="Auto" />    <!-- summary text -->
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" CornerRadius="7"
                            BorderBrush="#806A5520" BorderThickness="1"
                            Background="#FF10131A"
                            Margin="0,0,10,0">
                        <Image Source="/Resources/foreman.png"
                               Width="30" Height="30"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="FOREMAN"
                                   FontSize="15" FontWeight="Bold"
                                   FontFamily="Segoe UI, Arial"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="agent safety"
                                   FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,1,0,0" />
                    </StackPanel>
                </StackPanel>

                <!-- One chip per harness that has alerts.  Empty = "all clear" hint. -->
                <ItemsControl Grid.Column="2" x:Name="HarnessPanel"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="3" Padding="7,3" Margin="0,0,8,0"
                                    Background="{Binding LevelBg}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding LevelLabel}"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="{Binding LevelFg}" />
                                    <TextBlock Text="  " />
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="10"
                                               Foreground="{Binding LevelFg}" />
                                    <TextBlock Text="  ·  " FontSize="10"
                                               Foreground="{Binding LevelFg}" Opacity="0.65" />
                                    <TextBlock Text="{Binding CountLabel}"
                                               FontSize="10"
                                               Foreground="{Binding LevelFg}" Opacity="0.85" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Grid.Column="3" x:Name="SummaryLabel"
                           FontSize="11"
                           FontFamily="Segoe UI, Arial"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource BackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="8"
                        Background="{StaticResource SurfaceRaisedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" Padding="14,10">
                    <StackPanel>
                        <TextBlock x:Name="ActiveAlertCountLabel"
                                   Text="0"
                                   Style="{StaticResource MetricValue}" />
                        <TextBlock Text="ACTIVE ALERTS"
                                   Style="{StaticResource MetricCaption}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" CornerRadius="8"
                        Background="{StaticResource SurfaceRaisedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" Padding="14,10">
                    <StackPanel>
                        <TextBlock x:Name="HarnessCountLabel"
                                   Text="0"
                                   Style="{StaticResource MetricValue}" />
                        <TextBlock Text="TRACKED HARNESSES"
                                   Style="{StaticResource MetricCaption}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" CornerRadius="8"
                        Background="{StaticResource SurfaceRaisedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" Padding="14,10">
                    <StackPanel>
                        <TextBlock x:Name="HighAlertCountLabel"
                                   Text="0"
                                   Style="{StaticResource MetricValue}" />
                        <TextBlock Text="HIGH OR CRITICAL"
                                   Style="{StaticResource MetricCaption}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" CornerRadius="8"
                        Background="{StaticResource SurfaceRaisedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" Padding="14,10">
                    <StackPanel>
                        <TextBlock x:Name="LastEventLabel"
                                   Text="none"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="LAST EVENT"
                                   Style="{StaticResource MetricCaption}" />
                    </StackPanel>
                </Border>

                <Border x:Name="McpClientsCard" Grid.Column="8" CornerRadius="8"
                        Background="{StaticResource SurfaceRaisedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" Padding="14,10"
                        ToolTipService.ShowDuration="20000">
                    <StackPanel>
                        <TextBlock x:Name="McpClientsLabel"
                                   Text="0"
                                   Style="{StaticResource MetricValue}" />
                        <TextBlock Text="MCP CLIENTS"
                                   Style="{StaticResource MetricCaption}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="10" CornerRadius="8"
                        Background="{StaticResource SurfaceRaisedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" Padding="14,10">
                    <StackPanel>
                        <TextBlock x:Name="NetCaptureLabel"
                                   Text="Off"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="NET METERING"
                                   Style="{StaticResource MetricCaption}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── Empty state (shown when no security alerts exist) ─────────────── -->
        <Grid Grid.Row="2" x:Name="EmptyPanel" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.78">
                <Border Width="82" Height="82" CornerRadius="14"
                        Background="#FF10131A"
                        BorderBrush="#664C3A16" BorderThickness="1"
                        Margin="0,0,0,16">
                    <Image Source="/Resources/foreman.png"
                           Width="76" Height="76"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>
                <TextBlock Text="No security alerts this session"
                           FontSize="16" FontWeight="SemiBold" FontFamily="Segoe UI, Arial"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Foreman is watching"
                           FontSize="12" FontFamily="Segoe UI, Arial"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,6,0,0" />
            </StackPanel>
        </Grid>

        <!-- ── Alert feed ─────────────────────────────────────────────────────── -->
        <!-- Click any row to open AlertDetailWindow for that event. -->
        <ListView Grid.Row="2" x:Name="AlertList"
                  Background="{StaticResource SurfaceBrush}"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  SelectionChanged="AlertList_SelectionChanged">

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="12,8,12,0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FF1A1C28" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FF22253A" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />   <!-- headline row -->
                                <RowDefinition Height="Auto" />   <!-- subline row (optional) -->
                            </Grid.RowDefinitions>

                            <!-- Headline: sev badge | tag badge | text | time | arrow -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />    <!-- severity badge -->
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="52" />    <!-- category tag badge -->
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />     <!-- headline text -->
                                    <ColumnDefinition Width="62" />    <!-- time ago -->
                                    <ColumnDefinition Width="12" />    <!-- › arrow -->
                                </Grid.ColumnDefinitions>

                                <!-- Severity badge (red/orange/yellow) -->
                                <Border Grid.Column="0" CornerRadius="3" Padding="4,2"
                                        Background="{Binding SeverityBrush}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SeverityLabel}"
                                               FontSize="9" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </Border>

                                <!-- Category tag badge (NET / CRED / ESC / HANG …) -->
                                <Border Grid.Column="2" CornerRadius="3" Padding="4,2"
                                        Background="{Binding TagBg}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TagBadge}"
                                               FontSize="9" FontWeight="Bold" Foreground="{Binding TagFg}"
                                               HorizontalAlignment="Center" />
                                </Border>

                                <!-- Headline text -->
                                <TextBlock Grid.Column="4" Text="{Binding Headline}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />

                                <!-- Relative time -->
                                <TextBlock Grid.Column="5" Text="{Binding TimeAgo}"
                                           FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />

                                <!-- Click indicator arrow -->
                                <TextBlock Grid.Column="6" Text="›"
                                           FontSize="14"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <!-- SubLine: command preview / escalation categories / hang details
                                 Collapsed when SubLine is empty (non-command events that have no extra detail). -->
                            <TextBlock Grid.Row="1"
                                       Text="{Binding SubLine}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       FontFamily="Consolas, Courier New"
                                       Margin="0,4,0,0"
                                       Visibility="{Binding SubLineVisibility}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- ── Footer toolbar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="#FF0D0F16"
                BorderBrush="#FF1E2030" BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Process Monitor" Click="OpenProcessMonitorClick" Margin="0,0,8,0" />
                    <Button Content="Harnesses" Click="OpenHarnessesClick" Margin="0,0,8,0" />
                    <Button Content="Behavior Metrics" Click="OpenBehaviorMetricsClick" Margin="0,0,8,0" />
                    <Button Content="Settings" Click="OpenSettingsClick" Margin="0,0,8,0" />
                    <Button Content="Connect agent" Click="ConnectAgentClick" Margin="0,0,8,0" />
                    <Button Content="Event Log" Click="OpenLogClick" Style="{StaticResource PrimaryButton}" />
                </StackPanel>
                <TextBlock x:Name="FooterText"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontSize="11" FontFamily="Segoe UI, Arial"
                           Foreground="{StaticResource TextMutedBrush}" />
            </Grid>
        </Border>
    </Grid>
</Window>
