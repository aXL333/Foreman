<Window x:Class="Foreman.App.Windows.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Foreman Agent Safety"
        Icon="/Resources/foreman.ico"
        Width="1080" Height="680"
        MinWidth="820" MinHeight="500"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI, Arial"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF222632" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FF4A5160" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF151820" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FF0B0D12" />
            <Setter Property="BorderBrush" Value="#FFE9C267" />
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI, Arial" />
        </Style>

        <Style x:Key="MetricCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>

        <!-- Clickable metric tile. Background/BorderBrush live in the style (not locally on each
             Border) so the hover trigger can actually win — a local value would override it. -->
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF222632" />
                    <Setter Property="BorderBrush" Value="#FF4A5160" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Dark-themed tabs ─────────────────────────────────────────────── -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TB" Background="Transparent" Padding="16,9" Margin="0,0,2,0"
                                CornerRadius="6,6,0,0" BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TB" Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TB" Property="Background" Value="{StaticResource SurfaceBrush}" />
                                <Setter TargetName="TB" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <TabControl x:Name="Tabs" Padding="0,8,0,0" SelectionChanged="TabsSelectionChanged">
      <TabItem Header="Overview">
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- r0: header -->
            <RowDefinition Height="Auto" />   <!-- r1: system meta lights -->
            <RowDefinition Height="Auto" />   <!-- r2: status strip -->
            <RowDefinition Height="Auto" />   <!-- r3: harness overview -->
            <RowDefinition Height="*" />      <!-- r4: content -->
            <RowDefinition Height="Auto" />   <!-- r5: footer toolbar -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#FF0B0D12"
                BorderBrush="#FF1E2030" BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />    <!-- FOREMAN brand -->
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />       <!-- harness chips -->
                    <ColumnDefinition Width="Auto" />    <!-- summary text -->
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="Auto" />    <!-- presence padlock -->
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" CornerRadius="7"
                            BorderBrush="#806A5520" BorderThickness="1"
                            Background="#FF10131A"
                            Margin="0,0,10,0">
                        <Image Source="/Resources/foreman.png"
                               Width="30" Height="30"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="FOREMAN"
                                   FontSize="15" FontWeight="Bold"
                                   FontFamily="Segoe UI, Arial"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="agent safety"
                                   FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,1,0,0" />
                    </StackPanel>
                </StackPanel>

                <!-- One chip per harness with activity (running, MCP, or alerts). Empty = all clear hint. -->
                <ItemsControl Grid.Column="2" x:Name="HarnessPanel"
                              VerticalAlignment="Center"
                              MouseLeftButtonUp="HarnessChipClick">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="3" Padding="7,3" Margin="0,0,8,0"
                                    Background="{Binding LevelBg}" Cursor="Hand"
                                    ToolTip="{Binding ToolTip}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding LevelLabel}"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="{Binding LevelFg}" />
                                    <TextBlock Text="  " />
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="10"
                                               Foreground="{Binding LevelFg}" />
                                    <TextBlock Text="{Binding TrustLabel}"
                                               FontSize="10"
                                               Foreground="{Binding LevelFg}" Opacity="0.75" />
                                    <TextBlock Text="{Binding McpLabel}"
                                               FontSize="10"
                                               Foreground="{Binding LevelFg}" Opacity="0.85" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Grid.Column="3" x:Name="SummaryLabel"
                           FontSize="11"
                           FontFamily="Segoe UI, Arial"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center" />

                <!-- ── Presence padlock: click to arm/disarm; animates shackle + glow on toggle ── -->
                <Button Grid.Column="5" x:Name="PadlockButton" Click="PadlockClick"
                        Background="Transparent" BorderThickness="0" Padding="8,3" Cursor="Hand"
                        VerticalAlignment="Center"
                        ToolTip="Presence lock — require a Windows Hello / security-key tap to weaken Foreman. Click to arm or disarm.">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="pbg" Background="{TemplateBinding Background}" CornerRadius="7"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="pbg" Property="Background" Value="#FF161A24" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="22" Height="26" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform><ScaleTransform x:Name="PadlockScale" /></Grid.RenderTransform>
                            <Grid.Effect><DropShadowEffect x:Name="PadlockGlow" BlurRadius="0" ShadowDepth="0" Color="#FF3FB950" /></Grid.Effect>
                            <!-- shackle (rotates open/closed around its left leg) -->
                            <Path StrokeThickness="2.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 5,13 L 5,9 A 6,6 0 0 1 17,9 L 17,13">
                                <Path.Stroke><SolidColorBrush x:Name="ShackleBrush" Color="#FF8B949E" /></Path.Stroke>
                                <Path.RenderTransform><RotateTransform x:Name="ShackleRotate" CenterX="5" CenterY="13" /></Path.RenderTransform>
                            </Path>
                            <!-- body + keyhole -->
                            <Border Width="18" Height="13" CornerRadius="3" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                <Border.Background><SolidColorBrush x:Name="LockBodyBrush" Color="#FF8B949E" /></Border.Background>
                                <Ellipse Width="3.6" Height="3.6" Fill="#FF0B0D12"
                                         VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-1,0,0" />
                            </Border>
                        </Grid>
                        <TextBlock x:Name="PadlockLabel" VerticalAlignment="Center" Margin="8,0,0,0"
                                   FontSize="11" FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ── System meta lights (presence, sidecar, extension, usage posture) ── -->
        <Border Grid.Row="1"
                Background="#FF0D0F14"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="MetaLightsPanel">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Background=Transparent makes the whole chip (not just the dot/text) hit-testable;
                                 click deep-links to the pertinent view (see MetaLightClick). -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0"
                                        ToolTip="{Binding ToolTip}"
                                        Background="Transparent" Cursor="Hand"
                                        MouseLeftButtonUp="MetaLightClick">
                                <Ellipse Width="8" Height="8" Fill="{Binding DotBrush}"
                                         Visibility="{Binding DotVisibility}"
                                         VerticalAlignment="Center" Margin="0,0,6,0" />
                                <!-- Capability entries (computer/browser use) render the SAME amber C/B pill as
                                     the per-harness cards, so the key is a real legend for those badges. -->
                                <Border Visibility="{Binding GlyphVisibility}" Opacity="{Binding GlyphOpacity}"
                                        CornerRadius="3" Padding="5,1" Background="#332608"
                                        VerticalAlignment="Center" Margin="0,0,6,0">
                                    <TextBlock Text="{Binding Glyph}" FontSize="10" FontWeight="Bold"
                                               Foreground="#E8B23C" />
                                </Border>
                                <TextBlock Text="{Binding Label}" FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource BackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Each tile is clickable and deep-links to the most useful view for that number.
                     The nested "Acknowledge all" button still wins clicks on itself (Button marks
                     MouseLeftButtonUp handled, so the tile handler doesn't also fire). -->
                <Border Grid.Column="0" Style="{StaticResource MetricCard}"
                        MouseLeftButtonUp="ActiveAlertsTileClick"
                        ToolTip="Open the event log filtered to alerts">
                    <StackPanel>
                        <TextBlock x:Name="ActiveAlertCountLabel"
                                   Text="0"
                                   Style="{StaticResource MetricValue}" />
                        <TextBlock Text="ACTIVE ALERTS"
                                   Style="{StaticResource MetricCaption}" />
                        <Button x:Name="AckAllButton" Content="Acknowledge all"
                                Click="AcknowledgeAllClick" Visibility="Collapsed"
                                FontSize="10" Padding="8,2" Margin="0,6,0,0"
                                HorizontalAlignment="Left" Cursor="Hand"
                                Background="#FF1E2028" BorderBrush="#FF303540"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                ToolTip="Mark every current alert as acknowledged (they stay in the log; the tray clears)" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource MetricCard}"
                        MouseLeftButtonUp="AgentsTileClick"
                        ToolTip="Open the Processes tab to see what's running">
                    <StackPanel>
                        <TextBlock x:Name="HarnessCountLabel"
                                   Text="0"
                                   Style="{StaticResource MetricValue}" />
                        <TextBlock Text="AGENTS RUNNING"
                                   Style="{StaticResource MetricCaption}" />
                        <TextBlock x:Name="AgentUsageLabel"
                                   FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,4,0,0"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource MetricCard}"
                        MouseLeftButtonUp="HighCriticalTileClick"
                        ToolTip="Open the event log filtered to High and Critical">
                    <StackPanel>
                        <TextBlock x:Name="HighAlertCountLabel"
                                   Text="0"
                                   Style="{StaticResource MetricValue}" />
                        <TextBlock Text="HIGH OR CRITICAL"
                                   Style="{StaticResource MetricCaption}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource MetricCard}"
                        MouseLeftButtonUp="LastEventTileClick"
                        ToolTip="Open the most recent event's details">
                    <StackPanel>
                        <TextBlock x:Name="LastEventLabel"
                                   Text="none"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="LAST EVENT"
                                   Style="{StaticResource MetricCaption}" />
                    </StackPanel>
                </Border>

                <Border x:Name="McpClientsCard" Grid.Column="8" Style="{StaticResource MetricCard}"
                        MouseLeftButtonUp="McpClientsTileClick"
                        ToolTipService.ShowDuration="20000">
                    <StackPanel>
                        <TextBlock x:Name="McpClientsLabel"
                                   Text="0"
                                   Style="{StaticResource MetricValue}" />
                        <TextBlock Text="MCP CLIENTS"
                                   Style="{StaticResource MetricCaption}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="10" Style="{StaticResource MetricCard}"
                        MouseLeftButtonUp="NetworkTileClick"
                        ToolTip="Per-process network capture (elevated sidecar) — click to open Settings">
                    <StackPanel>
                        <TextBlock x:Name="NetCaptureLabel"
                                   Text="Off"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="NETWORK"
                                   Style="{StaticResource MetricCaption}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── Harness overview cards ─────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="HARNESS STATUS"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock HorizontalAlignment="Right"
                               Text="click a card → live detail"
                               FontSize="10"
                               Foreground="{StaticResource TextMutedBrush}" />
                </Grid>
                <TextBlock x:Name="NoConnectedHarnessText"
                           Text="No agents running or connected yet — use Connect agent to link one."
                           FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           Visibility="Collapsed" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="HarnessOverviewPanel"
                                  MouseLeftButtonUp="HarnessOverviewClick">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="168" Margin="0,0,10,0"
                                        CornerRadius="8"
                                        Background="{StaticResource SurfaceRaisedBrush}"
                                        BorderBrush="{Binding BorderBrush}"
                                        BorderThickness="1"
                                        Padding="12,10" Cursor="Hand"
                                        ToolTip="{Binding ToolTip}">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <Border HorizontalAlignment="Right" CornerRadius="3" Padding="5,2"
                                                    Background="{Binding StatusBackground}">
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontSize="9" FontWeight="Bold"
                                                           Foreground="{Binding StatusForeground}" />
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding Subtitle}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Margin="0,6,0,0"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding TrustLabel}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentBrush}" />
                                            <TextBlock Text="  ·  " FontSize="10"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Text="{Binding EscalationLabel}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="{Binding EscalationForeground}" />
                                            <!-- Capability chips: C = computer-use (desktop control), B = browser automation. Hover explains. -->
                                            <Border Visibility="{Binding ComputerUseVisibility}" Margin="8,0,0,0" CornerRadius="3" Padding="5,1"
                                                    Background="#332608" ToolTip="{Binding ComputerUseTip}">
                                                <TextBlock Text="C" FontSize="10" FontWeight="Bold" Foreground="#E8B23C" />
                                            </Border>
                                            <Border Visibility="{Binding BrowserUseVisibility}" Margin="4,0,0,0" CornerRadius="3" Padding="5,1"
                                                    Background="#332608" ToolTip="{Binding BrowserUseTip}">
                                                <TextBlock Text="B" FontSize="10" FontWeight="Bold" Foreground="#E8B23C" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding DetailLine}"
                                                   FontSize="10"
                                                   Foreground="{Binding DetailForeground}"
                                                   Margin="0,6,0,0"
                                                   TextTrimming="CharacterEllipsis" />
                                        <ItemsControl ItemsSource="{Binding Lights}" Margin="0,8,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Ellipse Width="8" Height="8" Fill="{Binding DotBrush}"
                                                             Margin="0,0,5,0"
                                                             ToolTip="{Binding ToolTip}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- ── Empty state (shown when no security alerts exist) ─────────────── -->
        <Grid Grid.Row="4" x:Name="EmptyPanel" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.78">
                <Border Width="82" Height="82" CornerRadius="14"
                        Background="#FF10131A"
                        BorderBrush="#664C3A16" BorderThickness="1"
                        Margin="0,0,0,16">
                    <Image Source="/Resources/foreman.png"
                           Width="76" Height="76"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>
                <TextBlock Text="No security alerts this session"
                           FontSize="16" FontWeight="SemiBold" FontFamily="Segoe UI, Arial"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Foreman Agent Safety is watching"
                           FontSize="12" FontFamily="Segoe UI, Arial"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,6,0,0" />
            </StackPanel>
        </Grid>

        <!-- ── Alert feed ─────────────────────────────────────────────────────── -->
        <!-- Click any row to open AlertDetailWindow for that event. -->
        <ListView Grid.Row="4" x:Name="AlertList"
                  Background="{StaticResource SurfaceBrush}"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  MouseLeftButtonUp="AlertList_MouseLeftButtonUp"
                  KeyDown="AlertList_KeyDown">

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="12,8,12,0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FF1A1C28" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FF22253A" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />   <!-- headline row -->
                                <RowDefinition Height="Auto" />   <!-- subline row (optional) -->
                            </Grid.RowDefinitions>

                            <!-- Headline: sev badge | tag badge | text | time | arrow -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />    <!-- severity badge -->
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="52" />    <!-- category tag badge -->
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />     <!-- headline text -->
                                    <ColumnDefinition Width="62" />    <!-- time ago -->
                                    <ColumnDefinition Width="12" />    <!-- › arrow -->
                                </Grid.ColumnDefinitions>

                                <!-- Severity badge (red/orange/yellow) -->
                                <Border Grid.Column="0" CornerRadius="3" Padding="4,2"
                                        Background="{Binding SeverityBrush}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SeverityLabel}"
                                               FontSize="9" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </Border>

                                <!-- Category tag badge (NET / CRED / ESC / HANG …) -->
                                <Border Grid.Column="2" CornerRadius="3" Padding="4,2"
                                        Background="{Binding TagBg}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TagBadge}"
                                               FontSize="9" FontWeight="Bold" Foreground="{Binding TagFg}"
                                               HorizontalAlignment="Center" />
                                </Border>

                                <!-- Headline text -->
                                <TextBlock Grid.Column="4" Text="{Binding Headline}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />

                                <!-- Relative time -->
                                <TextBlock Grid.Column="5" Text="{Binding TimeAgo}"
                                           FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />

                                <!-- Click indicator arrow -->
                                <TextBlock Grid.Column="6" Text="›"
                                           FontSize="14"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <!-- SubLine: command preview / escalation categories / hang details
                                 Collapsed when SubLine is empty (non-command events that have no extra detail). -->
                            <TextBlock Grid.Row="1"
                                       Text="{Binding SubLine}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       FontFamily="Consolas, Courier New"
                                       Margin="0,4,0,0"
                                       Visibility="{Binding SubLineVisibility}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- ── Footer toolbar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="5"
                Background="#FF0D0F16"
                BorderBrush="#FF1E2030" BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="MuteWarningsButton" Content="Mute warnings" Click="MuteWarningsClick" Margin="0,0,8,0"
                            ToolTip="Mute warning (yellow) alert toasts so they don't spam. Alerts still log and show in the dashboard." />
                    <Button Content="Connect agent" Click="ConnectAgentClick" Margin="0,0,8,0" />
                    <Button Content="Settings" Click="OpenSettingsClick" />
                </StackPanel>
                <TextBlock x:Name="FooterText"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontSize="11" FontFamily="Segoe UI, Arial"
                           Foreground="{StaticResource TextMutedBrush}" />
            </Grid>
        </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Processes"><ContentControl x:Name="ProcessSlot" /></TabItem>
      <TabItem Header="Harnesses"><ContentControl x:Name="HarnessSlot" /></TabItem>
      <TabItem Header="Behavior"><ContentControl x:Name="BehaviorSlot" /></TabItem>
      <TabItem Header="Event Log"><ContentControl x:Name="LogSlot" /></TabItem>
      <TabItem Header="Vault"><ContentControl x:Name="VaultSlot" /></TabItem>
      <TabItem Header="Approvals"><ContentControl x:Name="ApprovalsSlot" /></TabItem>
      <TabItem Header="Setup"><ContentControl x:Name="SetupSlot" /></TabItem>
      <TabItem Header="Mutes"><ContentControl x:Name="MutesSlot" /></TabItem>
      <TabItem Header="Connect"><ContentControl x:Name="ConnectSlot" /></TabItem>
    </TabControl>
</Window>
