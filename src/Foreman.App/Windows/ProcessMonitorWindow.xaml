<Window x:Class="Foreman.App.Windows.ProcessMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Foreman — Process Monitor"
        Icon="/Resources/foreman.ico"
        Width="1160" Height="520"
        MinWidth="680" MinHeight="340"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI, Arial">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF1E2028" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#FF303540" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <!-- Row container for the process list -->
        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#FF1E2028" />
            <Setter Property="Padding" Value="0,2,0,2" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF22253A" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF1A1C28" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#FF14161E" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="#FF1E2028" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- toolbar -->
            <RowDefinition Height="10"   />
            <RowDefinition Height="*"    />   <!-- process list -->
            <RowDefinition Height="10"   />
            <RowDefinition Height="Auto" />   <!-- detail / status bar -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ──────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="PROCESS MONITOR" FontSize="12" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center" Margin="0,0,16,0" />
                <CheckBox x:Name="HarnessOnlyCheck"
                          Content="Harnesses only"
                          IsChecked="True"
                          Checked="FilterChanged" Unchecked="FilterChanged"
                          Margin="0,0,12,0" />
                <CheckBox x:Name="HideTerminatedCheck"
                          Content="Hide terminated"
                          IsChecked="True"
                          Checked="FilterChanged" Unchecked="FilterChanged" />
                <TextBlock Text="I/O = total I/O · Net needs Run Elevated"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="10" VerticalAlignment="Center" Margin="16,0,0,0" />
            </StackPanel>

            <!-- live refresh indicator + count -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock x:Name="CountLabel"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0" />
                <TextBlock x:Name="RefreshLabel" Text="⟳"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="14" VerticalAlignment="Center"
                           ToolTip="Auto-refreshes every 2 seconds" />
            </StackPanel>
        </Grid>

        <!-- ── Process list ─────────────────────────────────────────────────── -->
        <ListView x:Name="ProcessList"
                  Grid.Row="2"
                  Background="#FF0D0F12"
                  BorderBrush="#FF303540"
                  BorderThickness="1"
                  SelectionMode="Single"
                  SelectionChanged="ProcessList_SelectionChanged"
                  PreviewMouseRightButtonDown="ProcessList_RightButtonDown"
                  VirtualizingStackPanel.IsVirtualizing="True">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Check on VirusTotal" Click="VirusTotalClick" />
                    <MenuItem Header="Copy SHA-256"        Click="CopyHashClick" />
                    <Separator />
                    <MenuItem Header="Copy executable path" Click="CopyPathClick" />
                    <MenuItem Header="Open file location"   Click="OpenLocationClick" />
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="State"  Width="74"  DisplayMemberBinding="{Binding StateLabel}" />
                    <GridViewColumn Header="PID"    Width="52"  DisplayMemberBinding="{Binding Pid}" />
                    <GridViewColumn Header="Name"   Width="140" DisplayMemberBinding="{Binding Name}" />
                    <GridViewColumn Header="Type"   Width="92"  DisplayMemberBinding="{Binding HarnessType}" />
                    <GridViewColumn Header="CPU"    Width="50"  DisplayMemberBinding="{Binding CpuLabel}" />
                    <GridViewColumn Header="Mem"    Width="64"  DisplayMemberBinding="{Binding MemLabel}" />
                    <GridViewColumn Header="I/O"    Width="66"  DisplayMemberBinding="{Binding IoLabel}" />
                    <GridViewColumn Header="GPU"    Width="50"  DisplayMemberBinding="{Binding GpuLabel}" />
                    <GridViewColumn Header="Net"    Width="44"  DisplayMemberBinding="{Binding NetLabel}" />
                    <GridViewColumn Header="Uptime" Width="62"  DisplayMemberBinding="{Binding UptimeLabel}" />
                    <GridViewColumn Header="Silent" Width="56"  DisplayMemberBinding="{Binding SilentLabel}" />
                    <GridViewColumn Header="Parent" Width="54"  DisplayMemberBinding="{Binding ParentPid}" />
                    <GridViewColumn Header="Hash (SHA-256)" Width="104" DisplayMemberBinding="{Binding HashLabel}" />
                    <GridViewColumn Header="Command line" Width="220" DisplayMemberBinding="{Binding CommandLine}" />
                </GridView>
            </ListView.View>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{Binding RowForeground}" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                    <Setter Property="BorderBrush" Value="#FF1E2028" />
                    <Setter Property="Padding" Value="0,3,0,3" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FF22253A" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FF1A1C28" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- ── Detail strip ─────────────────────────────────────────────────── -->
        <Border Grid.Row="4" Background="#FF14161E" CornerRadius="4" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Command-line for selected process -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="COMMAND LINE" FontSize="9" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,3" />
                    <TextBlock x:Name="CmdLineDetail"
                               Text="— select a process —"
                               FontFamily="Consolas, Courier New"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!-- Action buttons for selected process -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="CopyPidBtn" Content="Copy PID"
                            Click="CopyPidClick" IsEnabled="False"
                            Margin="0,0,6,0" />
                    <Button x:Name="CopyCmdBtn" Content="Copy cmd"
                            Click="CopyCmdClick" IsEnabled="False" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
