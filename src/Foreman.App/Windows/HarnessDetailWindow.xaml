<Window x:Class="Foreman.App.Windows.HarnessDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Foreman.App.Windows"
        Title="Harness detail"
        Icon="/Resources/foreman.ico"
        Width="640" Height="760"
        MinWidth="520" MinHeight="500"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI, Arial"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <local:UsageFillConverter x:Key="FillConv" Mode="Fill" />
        <local:UsageFillConverter x:Key="RestConv" Mode="Rest" />

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF222632" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FF4A5160" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <!-- One usage metric row: label, thin bar, value -->
        <DataTemplate x:Key="UsageBarTemplate">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                <Grid Grid.Column="1" Height="6" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Border Background="#FF20242E" CornerRadius="3" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding Fraction, Converter={StaticResource FillConv}}" />
                            <ColumnDefinition Width="{Binding Fraction, Converter={StaticResource RestConv}}" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{Binding BarBrush}" CornerRadius="3" />
                    </Grid>
                </Grid>
                <TextBlock Grid.Column="2" Text="{Binding ValueText}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"
                           MinWidth="74" TextAlignment="Right" />
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FF0B0D12" BorderBrush="#FF1E2030" BorderThickness="0,0,0,1"
                Padding="16,14">
            <StackPanel>
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock x:Name="SubtitleText" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="4" Padding="8,4"
                            Background="{Binding ElementName=_dummy}" x:Name="StatusBadge">
                        <TextBlock x:Name="StatusBadgeText" FontSize="10" FontWeight="Bold" />
                    </Border>
                </Grid>
                <TextBlock x:Name="DescriptionText" FontSize="11" TextWrapping="Wrap"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,10,0,0" />
                <WrapPanel x:Name="BadgePanel" Margin="0,10,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,14">
            <StackPanel>
                <!-- Live usage -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="LIVE USAGE (PROCESS TREE)" Style="{StaticResource SectionHeader}" Margin="0" />
                            <TextBlock x:Name="UsageHintText" HorizontalAlignment="Right" FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </Grid>
                        <ItemsControl x:Name="UsageBars" ItemTemplate="{StaticResource UsageBarTemplate}" />
                        <TextBlock x:Name="NoUsageText" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   Visibility="Collapsed"
                                   Text="Not running — start this harness to see live CPU, RAM, GPU and I/O." />
                    </StackPanel>
                </Border>

                <!-- Behavior / security -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="BEHAVIOR &amp; SECURITY" Style="{StaticResource SectionHeader}" />
                        <ItemsControl x:Name="BehaviorRows">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Key}" FontSize="11"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="11"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- MCP sessions -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="MCP SESSIONS" Style="{StaticResource SectionHeader}" />
                        <ItemsControl x:Name="McpRows">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="11" Margin="0,0,0,3"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="NoMcpText" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   Text="No MCP session connected for this harness." Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <!-- Processes -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock x:Name="ProcessHeader" Text="PROCESSES" Style="{StaticResource SectionHeader}" />
                        <ItemsControl x:Name="ProcessRows">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF14171E" CornerRadius="6" Padding="10,7" Margin="0,0,0,6">
                                        <StackPanel>
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                    <TextBlock Text="{Binding PidLabel}" FontSize="11"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               Margin="8,0,0,0" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock HorizontalAlignment="Right" Text="{Binding UsageLabel}"
                                                           FontSize="11" FontFamily="Consolas, Courier New"
                                                           Foreground="{StaticResource AccentBrush}" />
                                            </Grid>
                                            <TextBlock Text="{Binding CommandLine}" FontSize="10"
                                                       FontFamily="Consolas, Courier New"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="NoProcessText" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   Text="No processes attributed to this harness right now." Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#FF0D0F16" BorderBrush="#FF1E2030" BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Harness settings" Click="OpenSettingsClick" Margin="0,0,8,0" />
                    <Button x:Name="ConnectButton" Content="Connect agent" Click="ConnectAgentClick" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="UpdatedText" FontSize="10" VerticalAlignment="Center" Margin="0,0,12,0"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <Button Content="Close" Click="CloseClick" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
