<UserControl x:Class="Foreman.App.Windows.CuApprovalsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}"
             TextOptions.TextFormattingMode="Display">

    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe UI, Arial" />
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI, Arial" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Computer-use actions awaiting your approval" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI, Arial" />
            <TextBlock Style="{StaticResource Muted}" Margin="0,6,0,0"
                       Text="The auditor held these (e.g. an agent self-signup, or a desktop action). Approve to let the executor run it, or reject to discard it. The origin / harness shown are the agent's CLAIMS, not verified facts. A desktop action also needs a Windows Hello tap to approve." />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <TextBlock x:Name="EmptyText" Text="No actions are awaiting approval." Style="{StaticResource Muted}"
                           HorizontalAlignment="Center" Margin="0,40,0,0" />
                <ItemsControl x:Name="HeldList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8" Padding="14" Margin="0,0,0,10"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI, Arial" />
                                    <TextBlock Text="{Binding Reason}" Style="{StaticResource Muted}" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding ArgsSummary}" Margin="0,6,0,0" FontSize="11"
                                               TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}"
                                               FontFamily="Consolas, Cascadia Mono, Segoe UI" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                        <Button Content="Reject" Click="RejectClick" Tag="{Binding ActionId}" Margin="0,0,8,0" />
                                        <Button Content="Approve" Click="ApproveClick" Tag="{Binding ActionId}"
                                                Background="{StaticResource AccentBrush}" Foreground="#FF0D0F12" FontWeight="Bold" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" HorizontalAlignment="Left"
                       FontSize="12" Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI, Arial" />
            <Button Content="Refresh" Click="RefreshClick" HorizontalAlignment="Right" />
        </Grid>
    </Grid>
</UserControl>
