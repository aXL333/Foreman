<UserControl x:Class="Foreman.App.Windows.VaultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource TextPrimaryBrush}"
             FontFamily="Segoe UI, Arial">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF14161E" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#FF303540" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="6,5" />
            <Setter Property="Margin" Value="0,3,0,10" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#FF14161E" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#FF303540" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="6,5" />
            <Setter Property="Margin" Value="0,3,0,10" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF1E2028" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#FF303540" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">

        <!-- ── ENROLL (first run) ─────────────────────────────────────────── -->
        <StackPanel x:Name="EnrollPanel" Visibility="Collapsed" VerticalAlignment="Top">
            <TextBlock Text="Set up the vault" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Keep your logins here so agents can sign in for you — without ever seeing the passwords. Pick a master password to protect them."
                       Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16" />
            <TextBlock Text="Master password" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
            <PasswordBox x:Name="EnrollPw" />
            <TextBlock Text="Confirm" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
            <PasswordBox x:Name="EnrollConfirm" />
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,2,0,14"
                       Text="Bound to this PC. The password is never stored — if you lose it, the vault can't be recovered." />
            <TextBlock x:Name="EnrollError" Foreground="#FFFF6666" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8" />
            <Button Content="Create vault" Click="EnrollClick" HorizontalAlignment="Left"
                    Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}" />
        </StackPanel>

        <!-- ── UNLOCK ─────────────────────────────────────────────────────── -->
        <StackPanel x:Name="UnlockPanel" Visibility="Collapsed" VerticalAlignment="Top">
            <TextBlock Text="Unlock the vault" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" />
            <TextBlock Text="Master password" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
            <PasswordBox x:Name="UnlockPw" />
            <TextBlock Text="A Windows Hello tap is also required when the presence lock is on."
                       Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,2,0,14" />
            <TextBlock x:Name="UnlockError" Foreground="#FFFF6666" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8" />
            <Button Content="Unlock" Click="UnlockClick" HorizontalAlignment="Left"
                    Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}" />
        </StackPanel>

        <!-- ── MANAGER (unlocked) ─────────────────────────────────────────── -->
        <Grid x:Name="ManagerPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Foreman Vault" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FF13251B" CornerRadius="10" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="unlocked" Foreground="#FF5DCAA5" FontSize="11" />
                    </Border>
                </StackPanel>
                <Button Content="Lock now" Click="LockClick" HorizontalAlignment="Right" Padding="10,5" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,14,0,0">
                <StackPanel>
                    <!-- Locked-time agent sign-ups awaiting operator review (P-BM4 deposit queue). Surfaced + reviewed
                         INLINE here, where the operator manages credentials — no separate window. -->
                    <Border x:Name="DepositReviewBanner" Visibility="Collapsed" Background="#FF2A2415"
                            BorderBrush="#FFE5A53A" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,14">
                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="DepositReviewText" Foreground="#FFE5A53A" FontWeight="SemiBold" FontSize="13" />
                                <TextBlock Text="An agent generated these while the vault was locked. Review each before it's saved."
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0" />
                            </StackPanel>
                            <Button Content="Review…" Click="ReviewDepositsClick" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Padding="14,6"
                                    Foreground="#FFE5A53A" BorderBrush="#FFE5A53A" />
                        </Grid>
                    </Border>

                    <!-- Inline review panel: replaces the old pop-up DepositReviewWindow. Shown when the operator clicks
                         Review; each item is Accept/Reject; Done collapses back to the list. -->
                    <Border x:Name="DepositReviewPanel" Visibility="Collapsed" Background="#FF14161E"
                            BorderBrush="#FF303540" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,14">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Sign-ups created while the vault was locked" FontWeight="SemiBold"
                                           FontSize="14" VerticalAlignment="Center" />
                                <Button Content="Done" Click="CloseReviewClick" HorizontalAlignment="Right" Padding="12,5" />
                            </Grid>
                            <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"
                                       Text="Accept to store one in the vault (operator-only, won't overwrite an existing login), or Reject to discard. The site, harness, and time are the agent's CLAIMS, not verified facts." />
                            <Border x:Name="ReviewWarningBox" Visibility="Collapsed" CornerRadius="6" Padding="10" Margin="0,10,0,0"
                                    Background="#33E53935" BorderBrush="#E53935" BorderThickness="1">
                                <TextBlock x:Name="ReviewWarningText" TextWrapping="Wrap" FontSize="12" FontWeight="SemiBold" />
                            </Border>
                            <ItemsControl x:Name="DepositList" Margin="0,10,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Padding="12" Margin="0,0,0,8"
                                                Background="#FF1A1D26" BorderBrush="#FF303540" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Sub}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,4,0,0" />
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                                    <Button Content="Reject" Click="RejectDepositClick" Tag="{Binding Id}" Padding="12,4" Margin="0,0,8,0" />
                                                    <Button Content="Accept" Click="AcceptDepositClick" Tag="{Binding Id}" Padding="12,4"
                                                            Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="ReviewEmptyText" Text="No pending sign-ups." Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0" Visibility="Collapsed" />
                            <Grid Margin="0,8,0,0">
                                <TextBlock x:Name="ReviewStatusText" VerticalAlignment="Center" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <Button x:Name="ClearQueueButton" Content="Finish &amp; clear queue" Click="ClearQueueClick"
                                        HorizontalAlignment="Right" Padding="12,5" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <ItemsControl x:Name="ItemsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#FF303540" BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding Origins}" VerticalAlignment="Center" Margin="0,0,10,0"
                                                           Foreground="{StaticResource TextMutedBrush}" FontFamily="Consolas" FontSize="11" />
                                                <Button Content="Edit" Click="EditItemClick" Tag="{Binding}" Padding="9,3" Margin="0,0,6,0" />
                                                <Button Content="Delete" Click="DeleteItemClick" Tag="{Binding}" Padding="9,3" />
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="{Binding Fields}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" />
                                            <TextBlock Text="{Binding Acl}" Foreground="{StaticResource AccentBrush}" FontSize="11" Margin="14,0,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="EmptyHint" Text="No credentials yet. Add one below."
                               Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="2,2,0,0" Visibility="Collapsed" />

                    <Button x:Name="AddButton" Content="+ Add credential" Click="ShowAddFormClick" Margin="0,12,0,0" HorizontalAlignment="Left" />

                    <!-- Add / edit form -->
                    <Border x:Name="AddForm" Visibility="Collapsed" Background="#FF14161E" BorderBrush="#FF303540"
                            BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock x:Name="AddFormTitle" Text="Add credential" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10" />
                            <TextBlock x:Name="EditKeepHint" Visibility="Collapsed" TextWrapping="Wrap" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"
                                       Text="Editing this credential — leave Password, 2FA, or Username blank to keep the current value." />
                            <TextBlock Text="Website — paste the address or type the host (e.g. github.com)" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="AddOrigins" />
                            <TextBlock Text="Username or email" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="AddUser" />
                            <TextBlock Text="Password" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                            <Grid Margin="0,3,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="AddPw" Grid.Column="0" Margin="0" />
                                <Button Grid.Column="1" Content="Generate" Click="GeneratePwClick" Margin="8,0,0,0" Padding="10,5" />
                            </Grid>
                            <TextBlock Text="Name (optional — defaults to the website)" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="AddName" />
                            <TextBlock Text="2FA setup key (optional)" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="AddTotp" FontFamily="Consolas" />
                            <TextBlock Text="Agents allowed to use it (blank = you only)" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="AddHarnesses" />
                            <TextBlock x:Name="AddError" Foreground="#FFFF6666" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Save" Click="SaveItemClick" Margin="0,0,8,0"
                                        Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}" />
                                <Button Content="Cancel" Click="CancelAddClick" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
