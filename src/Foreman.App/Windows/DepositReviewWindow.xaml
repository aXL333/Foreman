<Window x:Class="Foreman.App.Windows.DepositReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pending sign-ups to review" Width="660" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe UI, Arial" />
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI, Arial" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Sign-ups created while the vault was locked" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI, Arial" />
            <TextBlock Style="{StaticResource Muted}" Margin="0,6,0,0"
                       Text="An agent generated + queued these passwords while the vault was locked. Accept to store one in the vault (operator-only, won't overwrite an existing login), or Reject to discard. The site, harness, and time are the agent's CLAIMS, not verified facts. Finish &amp; clear empties the queue." />
        </StackPanel>

        <Border x:Name="WarningBox" Grid.Row="1" CornerRadius="6" Padding="10" Margin="0,0,0,10" Visibility="Collapsed"
                Background="#33E53935" BorderBrush="#E53935" BorderThickness="1">
            <TextBlock x:Name="WarningText" TextWrapping="Wrap" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI, Arial" />
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>
                <TextBlock x:Name="EmptyText" Text="No pending sign-ups." Style="{StaticResource Muted}"
                           HorizontalAlignment="Center" Margin="0,40,0,0" />
                <ItemsControl x:Name="DepositList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8" Padding="14" Margin="0,0,0,10"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI, Arial" />
                                    <TextBlock Text="{Binding Sub}" Style="{StaticResource Muted}" Margin="0,4,0,0" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                        <Button Content="Reject" Click="RejectClick" Tag="{Binding Id}" Margin="0,0,8,0" />
                                        <Button Content="Accept" Click="AcceptClick" Tag="{Binding Id}"
                                                Background="{StaticResource AccentBrush}" Foreground="#FF0D0F12" FontWeight="Bold" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" HorizontalAlignment="Left"
                       FontSize="12" Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI, Arial" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ClearButton" Content="Finish &amp; clear queue" Click="ClearClick" Margin="0,0,8,0" />
                <Button Content="Close" Click="CloseClick" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
