<Window x:Class="Foreman.App.Windows.AlertDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Foreman — Alert Detail"
        Icon="/Resources/foreman.ico"
        Width="780" Height="560"
        MinWidth="680" MinHeight="400"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI, Arial"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineHeight" Value="20" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF1E2028" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#FF303540" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- r0: severity badge + event type label -->
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />   <!-- r2: timestamp · source -->
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />   <!-- r4: rule badge (command alerts only) -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />   <!-- r6: originating process (command alerts only) -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />   <!-- r8: command line box -->
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />      <!-- r10: scrollable why + what-to-do -->
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />   <!-- r12: action buttons -->
        </Grid.RowDefinitions>

        <!-- ── Header ────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="4" Padding="10,4"
                    Background="{Binding SeverityBackground}">
                <TextBlock Text="{Binding SeverityLabel}"
                           Foreground="White" FontWeight="Bold" FontSize="12"
                           VerticalAlignment="Center" />
            </Border>

            <TextBlock Grid.Column="2" Text="{Binding EventTypeLabel}"
                       FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="{StaticResource TextPrimaryBrush}" />
        </Grid>

        <!-- ── Timestamp · Source ────────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <TextBlock Text="{Binding TimestampLabel}"
                       Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                       FontFamily="Consolas, Courier New" />
            <TextBlock Text="  ·  "
                       Foreground="{StaticResource TextMutedBrush}" FontSize="11" />
            <TextBlock Text="{Binding Source}"
                       Foreground="{StaticResource TextMutedBrush}" FontSize="11" />
        </StackPanel>

        <!-- ── Rule badge (CommandAlertEvent only) ───────────────────────── -->
        <Border Grid.Row="4" Background="#FF1A1C24" CornerRadius="4" Padding="12,8"
                Visibility="{Binding RuleInfoVisibility}">
            <StackPanel>
                <TextBlock Text="RULE TRIGGERED" Style="{StaticResource SectionHeader}" />
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <Border Background="#FF12141A" CornerRadius="3" Padding="5,2" Margin="0,0,8,0">
                        <TextBlock Text="{Binding RuleId}"
                                   FontFamily="Consolas, Courier New" FontSize="11"
                                   Foreground="{StaticResource AccentBrush}" />
                    </Border>
                    <TextBlock Text="{Binding RuleName}"
                               FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Originating process (CommandAlertEvent only) ───────────────── -->
        <Border Grid.Row="6" Background="#FF1A1C24" CornerRadius="4" Padding="12,8"
                Visibility="{Binding ProcessInfoVisibility}">
            <StackPanel>
                <TextBlock Text="ORIGINATING PROCESS" Style="{StaticResource SectionHeader}" />
                <!-- process name + pid -->
                <TextBlock Text="{Binding ProcessLine}"
                           FontFamily="Consolas, Courier New" FontSize="11"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,2,0,0" />
                <!-- harness type / child-of label -->
                <TextBlock Text="{Binding HarnessLine}"
                           FontSize="11" FontFamily="Segoe UI, Arial"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,3,0,0"
                           Visibility="{Binding HarnessLineVisibility}" />
                <!-- escalation badge + session alert summary -->
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                            Visibility="{Binding EscalationLineVisibility}">
                    <Border CornerRadius="3" Padding="5,2" Margin="0,0,8,0"
                            Background="{Binding EscalationBadgeBg}">
                        <TextBlock Text="{Binding EscalationLevelLabel}"
                                   Foreground="{Binding EscalationBadgeFg}"
                                   FontWeight="Bold" FontSize="10"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="{Binding EscalationSummary}"
                               FontSize="11" FontFamily="Segoe UI, Arial"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Command line ──────────────────────────────────────────────── -->
        <Border Grid.Row="8" Background="#FF0D0F12" CornerRadius="4" Padding="12,8"
                Visibility="{Binding CommandLineVisibility}">
            <StackPanel>
                <TextBlock Text="COMMAND" Style="{StaticResource SectionHeader}" />
                <TextBox Text="{Binding CommandLine, Mode=OneWay}"
                         IsReadOnly="True" Background="Transparent" BorderThickness="0"
                         FontFamily="Consolas, Courier New" FontSize="11"
                         Foreground="#FFCC9966" TextWrapping="Wrap"
                         MaxHeight="72" IsTabStop="False" />
            </StackPanel>
        </Border>

        <!-- ── Why dangerous + What to do ───────────────────────────────── -->
        <ScrollViewer Grid.Row="10" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="WHY THIS IS DANGEROUS" Style="{StaticResource SectionHeader}" />
                <TextBlock Text="{Binding WhyDangerous}"
                           Style="{StaticResource BodyText}" Margin="0,0,0,18" />

                <TextBlock Text="RECOMMENDED ACTION" Style="{StaticResource SectionHeader}" />
                <TextBlock Text="{Binding RecommendedAction}"
                           Style="{StaticResource BodyText}" />
            </StackPanel>
        </ScrollViewer>

        <!-- ── Buttons ───────────────────────────────────────────────────── -->
        <Grid Grid.Row="12">
            <!-- Kill is isolated on the far left, away from Close/Acknowledge, so it can't be hit by accident. -->
            <Button Content="Kill/End Process" Click="KillProcessClick" HorizontalAlignment="Left"
                    Background="#FF34191A" BorderBrush="#FF8A3A3A"
                    Foreground="#FFFFDAD8" MinWidth="132"
                    ToolTip="Terminate the process this alert is about (after confirmation)." />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="AskHarnessButton" Content="Ask Harness" Click="AskHarnessClick" Margin="0,0,8,0"
                        Background="#FF17243A" BorderBrush="#FF3E6FA8"
                        Foreground="#FFE5EEF8" MinWidth="104"
                        ToolTip="Ask the harness that caused this alert to justify and/or act on it." />
                <Button x:Name="SendForAuditButton" Content="Send for Audit" Click="SendForAuditClick" Margin="0,0,8,0"
                        Background="#FF1A2A1F" BorderBrush="#FF3E8A57"
                        Foreground="#FFDDF8E5" MinWidth="116"
                        ToolTip="Route this alert to a different agent for an independent review (alarming behavior only)." />
                <Button Content="Acknowledge" Click="AcknowledgeClick" Margin="0,0,8,0" />
                <Button Content="Open Log"    Click="OpenLogClick"    Margin="0,0,8,0" />
                <Button Content="Close"       Click="CloseClick"
                        Background="{StaticResource AccentBrush}"
                        Foreground="#FF0D0F12" FontWeight="Bold" Padding="18,6" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
