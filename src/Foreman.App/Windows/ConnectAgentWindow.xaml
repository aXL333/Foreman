<Window x:Class="Foreman.App.Windows.ConnectAgentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connect an agent — Foreman Agent Safety"
        Width="720" Height="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe UI, Arial" />
        </Style>
        <Style x:Key="Mono" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontFamily" Value="Consolas, monospace" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI, Arial" />
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI, Arial" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Connect an agent to Foreman Agent Safety" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI, Arial" />
            <TextBlock Style="{StaticResource Muted}" Margin="0,6,0,0"
                       Text="Foreman Agent Safety runs a local MCP server your AI agent connects to. That connection is how Foreman reports status to the agent, how the agent can pre-flight a command, and how 'Ask Harness' reaches it. Pick your agent below, then restart it." />
            <Border Margin="0,10,0,0" CornerRadius="6" Padding="10,7"
                    Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <TextBlock x:Name="ConnectedText" TextWrapping="Wrap" FontSize="12"
                           Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI, Arial" />
            </Border>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="Connect all agents" Click="ConnectAllClick"
                        Background="{StaticResource AccentBrush}" Foreground="#FF0D0F12" FontWeight="Bold" />
                <TextBlock Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="10,0,0,0"
                           Text="Writes a fresh-token &quot;foreman&quot; entry for every agent that's running, configured, or installed — connects new agents and repairs stale tokens in one click. Restart each agent afterward." />
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Claude Code -->
                <Border CornerRadius="8" Padding="14" Margin="0,0,0,12"
                        Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Claude Code" Style="{StaticResource CardTitle}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,10"
                                   Text="Easiest: let Foreman Agent Safety add the entry for you — it writes a user-scope &quot;foreman&quot; server into ~/.claude.json (a backup of the original is saved first)." />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Connect automatically" Click="ConnectClaudeClick" Margin="0,0,8,0"
                                    Background="{StaticResource AccentBrush}" Foreground="#FF0D0F12" FontWeight="Bold" />
                            <Button Content="Copy CLI command" Click="CopyCliClick" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,4"
                                   Text="Or paste this into ~/.claude.json (merge into the top-level mcpServers object):" />
                        <TextBox x:Name="ClaudeJsonBox" Style="{StaticResource Mono}" Height="124" />
                        <Button Content="Copy JSON" Click="CopyClaudeJsonClick" HorizontalAlignment="Left" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Codex -->
                <Border CornerRadius="8" Padding="14" Margin="0,0,0,12"
                        Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Codex" Style="{StaticResource CardTitle}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,10"
                                   Text="Easiest: let Foreman Agent Safety add the entry for you. It writes a user-scope &quot;foreman&quot; server into ~/.codex/config.toml and adds a marked Foreman Agent Safety section to ~/.codex/AGENTS.md so Codex knows how to receive and answer Ask Harness and audit prompts." />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Connect automatically" Click="ConnectCodexClick" Margin="0,0,8,0"
                                    Background="{StaticResource AccentBrush}" Foreground="#FF0D0F12" FontWeight="Bold" />
                            <Button Content="Copy TOML" Click="CopyCodexTomlClick" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,4"
                                   Text="Or paste this into ~/.codex/config.toml, then add the Foreman Agent Safety MCP Monitor section to ~/.codex/AGENTS.md and restart Codex:" />
                        <TextBox x:Name="CodexTomlBox" Style="{StaticResource Mono}" Height="112" />
                    </StackPanel>
                </Border>

                <!-- Cursor -->
                <Border CornerRadius="8" Padding="14" Margin="0,0,0,12"
                        Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Cursor" Style="{StaticResource CardTitle}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,10"
                                   Text="Easiest: let Foreman Agent Safety add the entry for you — it writes a &quot;foreman&quot; remote server into Cursor's ~/.cursor/mcp.json (a backup of the original is saved first)." />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Connect automatically" Click="ConnectCursorClick" Margin="0,0,8,0"
                                    Background="{StaticResource AccentBrush}" Foreground="#FF0D0F12" FontWeight="Bold" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,4"
                                   Text="Or merge this into ~/.cursor/mcp.json (the mcpServers object), then restart Cursor or refresh the server in Settings → Tools &amp; MCP:" />
                        <TextBox x:Name="CursorJsonBox" Style="{StaticResource Mono}" Height="124" />
                        <Button Content="Copy JSON" Click="CopyCursorJsonClick" HorizontalAlignment="Left" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- OpenCode -->
                <Border CornerRadius="8" Padding="14" Margin="0,0,0,12"
                        Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="OpenCode" Style="{StaticResource CardTitle}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,10"
                                   Text="Easiest: let Foreman Agent Safety add the entry for you — it writes a remote &quot;foreman&quot; server into the mcp object of OpenCode's opencode.json (a backup of the original is saved first)." />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Connect automatically" Click="ConnectOpenCodeClick" Margin="0,0,8,0"
                                    Background="{StaticResource AccentBrush}" Foreground="#FF0D0F12" FontWeight="Bold" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,4"
                                   Text="Or merge this into opencode.json (the top-level mcp object), then restart OpenCode:" />
                        <TextBox x:Name="OpenCodeJsonBox" Style="{StaticResource Mono}" Height="150" />
                        <Button Content="Copy JSON" Click="CopyOpenCodeJsonClick" HorizontalAlignment="Left" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- GitHub Copilot CLI -->
                <Border CornerRadius="8" Padding="14" Margin="0,0,0,12"
                        Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="GitHub Copilot CLI" Style="{StaticResource CardTitle}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,10"
                                   Text="Easiest: let Foreman Agent Safety add the entry for you — it writes an HTTP &quot;foreman&quot; server into ~/.copilot/mcp-config.json (a backup of the original is saved first)." />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Connect automatically" Click="ConnectCopilotClick" Margin="0,0,8,0"
                                    Background="{StaticResource AccentBrush}" Foreground="#FF0D0F12" FontWeight="Bold" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,4"
                                   Text="Or merge this into ~/.copilot/mcp-config.json (the mcpServers object), then restart Copilot CLI or run /mcp:" />
                        <TextBox x:Name="CopilotJsonBox" Style="{StaticResource Mono}" Height="150" />
                        <Button Content="Copy JSON" Click="CopyCopilotJsonClick" HorizontalAlignment="Left" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Gemini CLI -->
                <Border CornerRadius="8" Padding="14" Margin="0,0,0,12"
                        Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Gemini CLI" Style="{StaticResource CardTitle}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,10"
                                   Text="Easiest: let Foreman Agent Safety add the entry for you — it writes a streamable-HTTP &quot;foreman&quot; server into ~/.gemini/settings.json (a backup of the original is saved first). Note Gemini uses httpUrl for streamable HTTP, not url." />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Connect automatically" Click="ConnectGeminiClick" Margin="0,0,8,0"
                                    Background="{StaticResource AccentBrush}" Foreground="#FF0D0F12" FontWeight="Bold" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,4"
                                   Text="Or merge this into ~/.gemini/settings.json (the mcpServers object), then restart Gemini CLI:" />
                        <TextBox x:Name="GeminiJsonBox" Style="{StaticResource Mono}" Height="124" />
                        <Button Content="Copy JSON" Click="CopyGeminiJsonClick" HorizontalAlignment="Left" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- LM Studio (caveat emptor) -->
                <Border CornerRadius="8" Padding="14" Margin="0,0,0,12"
                        Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="LM Studio" Style="{StaticResource CardTitle}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,10"
                                   Text="Writes a remote &quot;foreman&quot; server into LM Studio's ~/.lmstudio/mcp.json (a backup is saved first; LM Studio reloads it automatically). Caveat emptor: LM Studio's MCP support is newer — if your build doesn't honour the Authorization header, Foreman will reject the connection as unauthorized. Verify it in LM Studio's MCP / Program panel after connecting." />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Connect automatically" Click="ConnectLmStudioClick" Margin="0,0,8,0"
                                    Background="{StaticResource AccentBrush}" Foreground="#FF0D0F12" FontWeight="Bold" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,4"
                                   Text="Or merge this into ~/.lmstudio/mcp.json (the mcpServers object):" />
                        <TextBox x:Name="LmStudioJsonBox" Style="{StaticResource Mono}" Height="124" />
                        <Button Content="Copy JSON" Click="CopyLmStudioJsonClick" HorizontalAlignment="Left" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- T3 Code (control plane) -->
                <Border CornerRadius="8" Padding="14" Margin="0,0,0,12"
                        Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="T3 Code (control plane)" Style="{StaticResource CardTitle}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,10"
                                   Text="T3 Code runs an underlying agent (Claude Code, Codex, or OpenCode). Connect that agent using its card above — T3 Code uses the same MCP server, and Foreman Agent Safety monitors T3 Code itself as the control plane. 'Connect automatically' copies the config to paste into whichever agent T3 Code drives." />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Copy config" Click="ConnectT3Click" Margin="0,0,8,0"
                                    Background="{StaticResource AccentBrush}" Foreground="#FF0D0F12" FontWeight="Bold" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,4"
                                   Text="Config for the agent T3 Code runs (merge into its mcpServers object):" />
                        <TextBox x:Name="T3Box" Style="{StaticResource Mono}" Height="124" />
                        <Button Content="Copy JSON" Click="CopyT3Click" HorizontalAlignment="Left" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Any other client -->
                <Border CornerRadius="8" Padding="14"
                        Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Any other MCP client" Style="{StaticResource CardTitle}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,10"
                                   Text="In your agent's MCP config, add an HTTP (streamable-HTTP) server using this URL and Authorization header:" />
                        <TextBox x:Name="GenericBox" Style="{StaticResource Mono}" Height="150" />
                        <Button Content="Copy" Click="CopyGenericClick" HorizontalAlignment="Left" Margin="0,6,0,0" />
                        <TextBlock x:Name="TokenNote" Style="{StaticResource Muted}" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <!-- Foreman browser extension (on-device, paired) -->
                <Border CornerRadius="8" Padding="14" Margin="0,12,0,0"
                        Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🔒 Foreman browser extension (on-device)" Style="{StaticResource CardTitle}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,10"
                                   Text="Links your browser to THIS machine only — nothing leaves the box. Click Pair, then enter the shown code in the extension's Options within 2 minutes. The code never crosses the wire; the extension proves it over a loopback challenge/response." />
                        <Button Content="Pair…" Click="PairExtensionClick" HorizontalAlignment="Left"
                                Background="{StaticResource AccentBrush}" Foreground="#FF0D0F12" FontWeight="Bold" />
                    </StackPanel>
                </Border>

                <!-- LiveWeave (on-device page builder, paired like an extension) -->
                <Border CornerRadius="8" Padding="14" Margin="0,12,0,0"
                        Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🌐 LiveWeave (on-device page builder)" Style="{StaticResource CardTitle}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,8"
                                   Text="LiveWeave pairs through the browser extension and renders into a local Foreman-owned canvas. In the extension options, choose LiveWeave mode and a driver harness before pairing." />
                        <TextBlock x:Name="LiveWeaveStatusText" Style="{StaticResource Muted}" Margin="0,0,0,8" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,10"
                                   Text="Once paired, only the selected driver harness, or the operator token, can drive LiveWeave. Empty driver means operator-only; any is an explicit all-harness mode." />
                        <Button Content="Pair LiveWeave…" Click="PairLiveWeaveClick" HorizontalAlignment="Left"
                                Background="{StaticResource AccentBrush}" Foreground="#FF0D0F12" FontWeight="Bold" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" HorizontalAlignment="Left"
                       FontSize="12" Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI, Arial" />
            <Button Content="Close" Click="CloseClick" HorizontalAlignment="Right" Padding="18,6"
                    Background="{StaticResource AccentBrush}" Foreground="#FF0D0F12" FontWeight="Bold" />
        </Grid>
    </Grid>
</Window>
