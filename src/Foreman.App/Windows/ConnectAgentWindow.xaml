<Window x:Class="Foreman.App.Windows.ConnectAgentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connect an agent — Foreman"
        Width="680" Height="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe UI, Arial" />
        </Style>
        <Style x:Key="Mono" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontFamily" Value="Consolas, monospace" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI, Arial" />
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI, Arial" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Connect an agent to Foreman" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI, Arial" />
            <TextBlock Style="{StaticResource Muted}" Margin="0,6,0,0"
                       Text="Foreman runs a local MCP server your AI agent connects to. That connection is how Foreman reports status to the agent, how the agent can pre-flight a command, and how 'Ask Harness' reaches it. Pick your agent below, then restart it." />
            <Border Margin="0,10,0,0" CornerRadius="6" Padding="10,7"
                    Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <TextBlock x:Name="ConnectedText" TextWrapping="Wrap" FontSize="12"
                           Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI, Arial" />
            </Border>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Claude Code -->
                <Border CornerRadius="8" Padding="14" Margin="0,0,0,12"
                        Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Claude Code" Style="{StaticResource CardTitle}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,10"
                                   Text="Easiest: let Foreman add the entry for you — it writes a user-scope &quot;foreman&quot; server into ~/.claude.json (a backup of the original is saved first)." />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Connect automatically" Click="ConnectClaudeClick" Margin="0,0,8,0"
                                    Background="{StaticResource AccentBrush}" Foreground="#FF0D0F12" FontWeight="Bold" />
                            <Button Content="Copy CLI command" Click="CopyCliClick" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,4"
                                   Text="Or paste this into ~/.claude.json (merge into the top-level mcpServers object):" />
                        <TextBox x:Name="ClaudeJsonBox" Style="{StaticResource Mono}" Height="124" />
                        <Button Content="Copy JSON" Click="CopyClaudeJsonClick" HorizontalAlignment="Left" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Any other client -->
                <Border CornerRadius="8" Padding="14"
                        Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Any other MCP client (Codex, OpenCode, …)" Style="{StaticResource CardTitle}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,10"
                                   Text="In your agent's MCP config, add an HTTP (streamable-HTTP) server using this URL and Authorization header:" />
                        <TextBox x:Name="GenericBox" Style="{StaticResource Mono}" Height="150" />
                        <Button Content="Copy" Click="CopyGenericClick" HorizontalAlignment="Left" Margin="0,6,0,0" />
                        <TextBlock x:Name="TokenNote" Style="{StaticResource Muted}" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" HorizontalAlignment="Left"
                       FontSize="12" Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI, Arial" />
            <Button Content="Close" Click="CloseClick" HorizontalAlignment="Right" Padding="18,6"
                    Background="{StaticResource AccentBrush}" Foreground="#FF0D0F12" FontWeight="Bold" />
        </Grid>
    </Grid>
</Window>
