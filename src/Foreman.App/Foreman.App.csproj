<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <AssemblyName>Foreman</AssemblyName>
    <RootNamespace>Foreman.App</RootNamespace>
    <PackageId>Foreman.AgentSafety</PackageId>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>Resources\foreman.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Foreman.Core\Foreman.Core.csproj" />
    <ProjectReference Include="..\Foreman.Monitor\Foreman.Monitor.csproj" />
    <ProjectReference Include="..\Foreman.McpServer\Foreman.McpServer.csproj" />
    <!-- Build the elevated sidecar first; its full output is copied next to the app (below).
         No assembly reference — it is a separate process, launched on demand. -->
    <ProjectReference Include="..\Foreman.EtwSidecar\Foreman.EtwSidecar.csproj" ReferenceOutputAssembly="false" />
    <!-- Same pattern for the opt-in guardian service (separate process, installed on demand). -->
    <ProjectReference Include="..\Foreman.Guardian\Foreman.Guardian.csproj" ReferenceOutputAssembly="false" />
    <!-- Medium-IL desktop computer-use sidecar (separate process, launched on demand by DesktopCuController). -->
    <ProjectReference Include="..\Foreman.CuSidecar\Foreman.CuSidecar.csproj" ReferenceOutputAssembly="false" />
    <!-- Medium-IL Local Agent Host pilot shim (separate process, launched on demand by PilotChannelController). -->
    <ProjectReference Include="..\Foreman.CuPilot\Foreman.CuPilot.csproj" ReferenceOutputAssembly="false" />
    <!-- Credential vault (native AEAD store + resolver); App supplies the DPAPI key protector. -->
    <ProjectReference Include="..\Foreman.Vault\Foreman.Vault.csproj" />
  </ItemGroup>

  <!-- Stage the sidecar under <app>\sidecar so ElevatedSidecarController can launch it. -->
  <Target Name="CopyEtwSidecar" AfterTargets="Build">
    <ItemGroup>
      <_SidecarOutput Include="$(MSBuildThisFileDirectory)..\Foreman.EtwSidecar\bin\$(Configuration)\$(TargetFramework)\**\*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(_SidecarOutput)"
          DestinationFiles="@(_SidecarOutput->'$(OutDir)sidecar\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <!-- Stage the desktop CU sidecar under <app>\cu-sidecar so DesktopCuController can launch it. -->
  <Target Name="CopyCuSidecar" AfterTargets="Build">
    <ItemGroup>
      <_CuSidecarOutput Include="$(MSBuildThisFileDirectory)..\Foreman.CuSidecar\bin\$(Configuration)\$(TargetFramework)\**\*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(_CuSidecarOutput)"
          DestinationFiles="@(_CuSidecarOutput->'$(OutDir)cu-sidecar\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <!-- Stage the Local Agent Host pilot shim under <app>\cu-pilot so PilotChannelController can launch it. -->
  <Target Name="CopyCuPilot" AfterTargets="Build">
    <ItemGroup>
      <_CuPilotOutput Include="$(MSBuildThisFileDirectory)..\Foreman.CuPilot\bin\$(Configuration)\$(TargetFramework)\**\*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(_CuPilotOutput)"
          DestinationFiles="@(_CuPilotOutput->'$(OutDir)cu-pilot\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <!-- Stage the guardian under <app>\guardian so the opt-in install action can launch it (elevated). -->
  <Target Name="CopyGuardian" AfterTargets="Build">
    <ItemGroup>
      <_GuardianOutput Include="$(MSBuildThisFileDirectory)..\Foreman.Guardian\bin\$(Configuration)\$(TargetFramework)\**\*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(_GuardianOutput)"
          DestinationFiles="@(_GuardianOutput->'$(OutDir)guardian\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="H.NotifyIcon.Wpf" />
    <PackageReference Include="Microsoft.Toolkit.Uwp.Notifications" />
    <PackageReference Include="System.Diagnostics.PerformanceCounter" />
    <PackageReference Include="System.Diagnostics.EventLog" />
    <PackageReference Include="System.Security.Cryptography.ProtectedData" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\*.ico" />
    <Resource Include="Resources\*.png" />
  </ItemGroup>

</Project>
