<Application x:Class="Foreman.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Dark base palette -->
            <Color x:Key="BackgroundColor">#FF0D0F12</Color>
            <Color x:Key="SurfaceColor">#FF13151A</Color>
            <Color x:Key="AccentColor">#FFE8B23C</Color>
            <Color x:Key="TextPrimaryColor">#FFE8EAF0</Color>
            <Color x:Key="TextMutedColor">#FF7A8090</Color>

            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />

            <!-- Severity brushes -->
            <SolidColorBrush x:Key="SeverityInfo"     Color="#FF4A90D9" />
            <SolidColorBrush x:Key="SeverityLow"      Color="#FF7EC878" />
            <SolidColorBrush x:Key="SeverityMedium"   Color="#FFE8B23C" />
            <SolidColorBrush x:Key="SeverityHigh"     Color="#FFEE7733" />
            <SolidColorBrush x:Key="SeverityCritical" Color="#FFDD3333" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
