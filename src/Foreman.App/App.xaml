<Application x:Class="Foreman.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Dark base palette -->
            <Color x:Key="BackgroundColor">#FF090A0D</Color>
            <Color x:Key="SurfaceColor">#FF111319</Color>
            <Color x:Key="AccentColor">#FFF0B84A</Color>
            <Color x:Key="TextPrimaryColor">#FFF0F2F6</Color>
            <Color x:Key="TextMutedColor">#FF8B93A4</Color>
            <Color x:Key="BorderColor">#FF242832</Color>
            <Color x:Key="SurfaceRaisedColor">#FF181B23</Color>

            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
            <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
            <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaisedColor}" />

            <!-- Severity brushes -->
            <SolidColorBrush x:Key="SeverityInfo"     Color="#FF4A90D9" />
            <SolidColorBrush x:Key="SeverityLow"      Color="#FF7EC878" />
            <SolidColorBrush x:Key="SeverityMedium"   Color="#FFE8B23C" />
            <SolidColorBrush x:Key="SeverityHigh"     Color="#FFEE7733" />
            <SolidColorBrush x:Key="SeverityCritical" Color="#FFDD3333" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
