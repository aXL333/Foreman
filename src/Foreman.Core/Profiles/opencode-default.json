{
  "name": "opencode-default",
  "version": "1.0",
  "description": "Default profile for OpenCode harness processes",
  "processMatch": {
    "executableNames": ["opencode.exe", "opencode"],
    "commandLineContains": ["opencode-ai", "@opencode-ai", "opencode/bin", "opencode/dist", ".opencode/"],
    "parentExecutableNames": []
  },
  "fileSystem": {
    "allowedWritePaths": [
      "%USERPROFILE%\\*",
      "%TEMP%\\opencode-*\\*",
      "%LOCALAPPDATA%\\opencode\\*",
      "%APPDATA%\\opencode\\*"
    ],
    "deniedPaths": [
      "C:\\Windows\\*",
      "C:\\Windows\\System32\\*",
      "%USERPROFILE%\\.ssh\\*",
      "%USERPROFILE%\\.aws\\*",
      "%USERPROFILE%\\.gnupg\\*"
    ],
    "enforceMode": "alert"
  },
  "commands": {
    "blockedPatterns": ["cred-001", "cred-004", "cred-005", "priv-002", "priv-003", "priv-004", "win-004"],
    "enforceMode": "alert"
  },
  "processLimits": {
    "maxRuntimeMinutes": 480,
    "hangThresholdMinutes": 10,
    "hookJamThresholdMinutes": 5
  },
  "claudeCodeIntegration": {
    "readSettingsJson": false,
    "trustGrantedPermissions": false
  },
  "alerts": {
    "notifyOnHang": true,
    "notifyOnOrphan": true,
    "notifyOnViolation": true,
    "suppressDuplicatesWindowMinutes": 5,
    "trustedHookPathMarkers": [".opencode\\hooks\\", ".opencode/hooks/"],
    "launcherSuppressedRuleIds": []
  }
}
