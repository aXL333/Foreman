{
  "name": "claude-code-default",
  "version": "1.0",
  "description": "Default profile for Claude Code harness processes",
  "processMatch": {
    "executableNames": ["claude-code.exe", "claude.exe"],
    "commandLineContains": ["@anthropic-ai/claude-code", "claude-code/dist", ".claude/"],
    "parentExecutableNames": []
  },
  "fileSystem": {
    "allowedWritePaths": [
      "%USERPROFILE%\\*",
      "%TEMP%\\claude-*\\*",
      "%LOCALAPPDATA%\\claude-*\\*"
    ],
    "deniedPaths": [
      "C:\\Windows\\*",
      "C:\\Windows\\System32\\*",
      "%USERPROFILE%\\.ssh\\*",
      "%USERPROFILE%\\.aws\\*",
      "%USERPROFILE%\\.gnupg\\*"
    ],
    "enforceMode": "alert"
  },
  "commands": {
    "blockedPatterns": ["cred-001", "cred-004", "cred-005", "priv-002", "priv-003", "priv-004", "win-004"],
    "enforceMode": "alert"
  },
  "processLimits": {
    "maxRuntimeMinutes": 480,
    "hangThresholdMinutes": 10,
    "hookJamThresholdMinutes": 5
  },
  "claudeCodeIntegration": {
    "readSettingsJson": true,
    "trustGrantedPermissions": true
  },
  "alerts": {
    "notifyOnHang": true,
    "notifyOnOrphan": true,
    "notifyOnViolation": true,
    "suppressDuplicatesWindowMinutes": 5
  }
}
