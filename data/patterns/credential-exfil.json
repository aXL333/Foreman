{
  "$schema": "https://foreman.local/pattern-schema/v1",
  "category": "credential-exfil",
  "version": "1.0",
  "rules": [
    {
      "id": "cred-001",
      "name": "SAM registry export",
      "severity": "critical",
      "description": "Exporting SAM or SYSTEM hive which contains password hashes",
      "pattern": "\\breg\\s+(?:export|save)\\s+HKLM\\\\(?:SAM|SYSTEM|SECURITY)\\b",
      "platforms": ["cmd", "powershell"],
      "falsePositiveTags": []
    },
    {
      "id": "cred-002",
      "name": "reading SSH private keys",
      "severity": "high",
      "description": "Accessing SSH private key files — potential credential theft",
      "pattern": "(?:cat|type|Get-Content)\\s+['\"]?[^\\s]*\\.ssh[/\\\\](?:id_rsa|id_ed25519|id_ecdsa|identity)(?!\\.(pub))['\"]?",
      "platforms": ["bash", "sh", "wsl", "cmd", "powershell"],
      "falsePositiveTags": ["ssh_key_read_allowed"]
    },
    {
      "id": "cred-003",
      "name": "reading AWS credentials file",
      "severity": "high",
      "description": "Reading ~/.aws/credentials — contains access keys",
      "pattern": "(?:cat|type|Get-Content)\\s+['\"]?[^\\s]*(?:\\.aws[/\\\\]credentials|[/\\\\]credentials)['\"]?\\s*$",
      "platforms": ["bash", "sh", "wsl", "cmd", "powershell"],
      "falsePositiveTags": ["aws_tooling_allowed"]
    },
    {
      "id": "cred-004",
      "name": "mimikatz patterns",
      "severity": "critical",
      "description": "Known mimikatz commands for credential dumping",
      "pattern": "(?:sekurlsa|lsadump|kerberos|dpapi)::|(?:privilege::debug|token::elevate|sekurlsa::logonpasswords)",
      "platforms": ["cmd", "powershell", "bash"],
      "falsePositiveTags": []
    },
    {
      "id": "cred-005",
      "name": "LSASS process dump",
      "severity": "critical",
      "description": "Dumping lsass.exe memory — primary credential harvesting technique",
      "pattern": "(?:procdump|minidump|rundll32).*lsass|tasklist.*lsass.*minidump|Out-Minidump.*lsass",
      "platforms": ["cmd", "powershell"],
      "falsePositiveTags": []
    },
    {
      "id": "cred-006",
      "name": "PowerShell credential prompt bypass",
      "severity": "medium",
      "description": "Extracting credentials from PSCredential or ConvertFrom-SecureString",
      "pattern": "\\[Runtime\\.InteropServices\\.Marshal\\]::PtrToStringAuto|ConvertFrom-SecureString.*Key|\\$credential\\.GetNetworkCredential\\(\\)\\.Password",
      "platforms": ["powershell"],
      "falsePositiveTags": []
    }
  ]
}
